    23                                  ; Macro Definition
    24                                  ; -------------------------------------------------------------------------
    25                                  %macro table_attach 9
    26                                      mov rdi, [table_handle]
    27                                      mov rsi, %1
    28                                      mov rdx, %2
    29                                      mov rcx, %3
    30                                      mov r8, %4
    31                                      mov r9, %5
    32                                      push %6    ; ypad
    33                                      push %7    ; xpad
    34                                      push %8    ; yoptions
    35                                      push %9    ; xoptions
    36                                      call gtk_table_attach
    37                                      add rsp, 32
    38                                  %endmacro
