     1                                  ; ==============================================================================
     2                                  ; Name        : simplewindow.asm
     3                                  ; Author      : Roberto Aguas Guerreiro [agguro]
     4                                  ; Description : A simple window blueprint demonstrating safe initialization
     5                                  ; ABI Status  : Compliant (Stack-aligned, Callee-saved preserved)
     6                                  ; ==============================================================================
     7                                  
     8                                  bits 64
     9                                  
    10                                  [list -]
    19                                  
    20                                  section .bss
    21                                       window:
    22 00000000 ????????????????             .handle:          resq      1
    23                                  
    24                                  section .data
    25 00000000 412073696D706C6520-          window.title:     db        "A simple window", 0
    25 00000009 77696E646F7700     
    26                                       signal:
    27 00000010 64657374726F7900             .destroy:         db        "destroy", 0
    28                                  
    29                                  section .text
    30                                       global _start
    31                                  
    32                                  _start:
    33                                       ; 1. Stack Alignment conform System V AMD64 ABI
    34 00000000 488B3C24                     mov        rdi, [rsp]
    35 00000004 488D742408                   lea        rsi, [rsp + 8]
    36 00000009 4989FC                       mov        r12, rdi
    37 0000000C 4989F5                       mov        r13, rsi
    38                                  
    39 0000000F 4883E4F0                     and        rsp, -16
    40 00000013 4883EC10                     sub        rsp, 16
    41 00000017 488D3C24                     lea        rdi, [rsp]
    42 0000001B 4C8927                       mov        [rdi], r12
    43 0000001E 488D742408                   lea        rsi, [rsp + 8]
    44 00000023 4C892E                       mov        [rsi], r13
    45                                  
    46 00000026 E8(00000000)                 call       gtk_init
    47                                  
    48                                       ; 2. Build Window
    49 0000002B BF00000000                   mov        rdi, GTK_WINDOW_TOPLEVEL
    50 00000030 E8(00000000)                 call       gtk_window_new
    51 00000035 48890425[00000000]           mov        qword [window.handle], rax
    52                                  
    53 0000003D 488B3C25[00000000]           mov        rdi, qword [window.handle]
    54 00000045 48BE-                        mov        rsi, window.title
    54 00000047 [0000000000000000] 
    55 0000004F E8(00000000)                 call       gtk_window_set_title
    56                                  
    57                                       ; 3. Signal Connections
    58 00000054 4531C9                       xor        r9d, r9d
    59 00000057 4531C0                       xor        r8d, r8d
    60 0000005A 4831C9                       xor        rcx, rcx
    61 0000005D 48BA-                        mov        rdx, gtk_main_quit
    61 0000005F [0000000000000000] 
    62 00000067 48BE-                        mov        rsi, signal.destroy
    62 00000069 [1000000000000000] 
    63 00000071 488B3C25[00000000]           mov        rdi, qword [window.handle]
    64 00000079 E8(00000000)                 call       g_signal_connect_data
    65                                  
    66 0000007E 488B3C25[00000000]           mov        rdi, qword [window.handle]
    67 00000086 E8(00000000)                 call       gtk_widget_show
    68 0000008B E8(00000000)                 call       gtk_main
    69                                  
    70 00000090 4831FF                       xor        rdi, rdi
    71 00000093 E8(00000000)                 call       exit
