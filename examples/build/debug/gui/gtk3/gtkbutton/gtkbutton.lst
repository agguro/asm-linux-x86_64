     1                                  ; ==============================================================================
     2                                  ; Name        : gtkbutton.asm
     3                                  ; Author      : Roberto Aguas Guerreiro [agguro]
     4                                  ; Description : Gtk widgets example with memory-loaded application icon
     5                                  ; ABI Status  : Compliant (Stack-aligned, Callee-saved preserved)
     6                                  ; ==============================================================================
     7                                  
     8                                  bits 64
     9                                  
    10                                  [list -]
    19                                  
    20                                  section .data
    21 00000000 <bin 18C3h>                  logo:          incbin    "../resources/pictures/logo.png"
    22                                       .size:         equ       $ - logo
    23                                  
    24                                       window:
    25 000018C3 0000000000000000             .handle:       dq        0
    26 000018CB 47746B427574746F6E-          .title:        db        "GtkButton", 0
    26 000018D4 00                 
    27                                  
    28                                       fixed:
    29 000018D5 0000000000000000             .handle:       dq        0
    30                                  
    31                                       button:
    32 000018DD 0000000000000000             .handle:       dq        0
    33 000018E5 5175697400                   .caption:      db        "Quit", 0
    34                                  
    35                                       signal:
    36 000018EA 64657374726F7900             .destroy:      db        "destroy", 0
    37 000018F2 636C69636B656400             .clicked:      db        "clicked", 0
    38                                  
    39 000018FA 0000000000000000             loader:        dq        0
    40 00001902 0000000000000000             pixbuffer:     dq        0
    41                                  
    42                                  section .text
    43                                       global _start
    44                                  
    45                                  _start:
    46                                       ; -------------------------------------------------------------------------
    47                                       ; 1. Retrieve argc/argv and enforce System V AMD64 ABI Stack Alignment
    48                                       ; -------------------------------------------------------------------------
    49 00000000 488B3C24                     mov        rdi, [rsp]                ; argc
    50 00000004 488D742408                   lea        rsi, [rsp + 8]            ; argv
    51 00000009 4989FC                       mov        r12, rdi
    52 0000000C 4989F5                       mov        r13, rsi
    53                                  
    54 0000000F 4883E4F0                     and        rsp, -16
    55 00000013 4883EC10                     sub        rsp, 16
    56 00000017 488D3C24                     lea        rdi, [rsp]
    57 0000001B 4C8927                       mov        [rdi], r12
    58 0000001E 488D742408                   lea        rsi, [rsp + 8]
    59 00000023 4C892E                       mov        [rsi], r13
    60                                  
    61 00000026 E8(00000000)                 call       gtk_init
    62                                  
    63                                       ; -------------------------------------------------------------------------
    64                                       ; 2. Generate Pixbuf from Embedded Asset in RAM
    65                                       ; -------------------------------------------------------------------------
    66 0000002B E8(00000000)                 call       gdk_pixbuf_loader_new
    67 00000030 48890425[FA180000]           mov        qword [loader], rax
    68                                  
    69 00000038 488B3C25[FA180000]           mov        rdi, qword [loader]
    70 00000040 48BE-                        mov        rsi, logo
    70 00000042 [0000000000000000] 
    71 0000004A BAC3180000                   mov        rdx, logo.size
    72 0000004F 4831C9                       xor        rcx, rcx                  ; GError** = NULL
    73 00000052 E8(00000000)                 call       gdk_pixbuf_loader_write
    74                                  
    75 00000057 488B3C25[FA180000]           mov        rdi, qword [loader]
    76 0000005F E8(00000000)                 call       gdk_pixbuf_loader_get_pixbuf
    77 00000064 48890425[02190000]           mov        qword [pixbuffer], rax
    78                                  
    79                                       ; -------------------------------------------------------------------------
    80                                       ; 3. Build and Configure Window Layout
    81                                       ; -------------------------------------------------------------------------
    82 0000006C BF00000000                   mov        rdi, GTK_WINDOW_TOPLEVEL
    83 00000071 E8(00000000)                 call       gtk_window_new
    84 00000076 48890425[C3180000]           mov        qword [window.handle], rax
    85                                  
    86 0000007E 488B3C25[C3180000]           mov        rdi, qword [window.handle]
    87 00000086 48BE-                        mov        rsi, window.title
    87 00000088 [CB18000000000000] 
    88 00000090 E8(00000000)                 call       gtk_window_set_title
    89                                  
    90 00000095 488B3C25[C3180000]           mov        rdi, qword [window.handle]
    91 0000009D BEF4010000                   mov        rsi, 500
    92 000000A2 BA2C010000                   mov        rdx, 300
    93 000000A7 E8(00000000)                 call       gtk_window_set_default_size
    94                                  
    95 000000AC 488B3C25[C3180000]           mov        rdi, qword [window.handle]
    96 000000B4 BE01000000                   mov        rsi, GTK_WIN_POS_CENTER
    97 000000B9 E8(00000000)                 call       gtk_window_set_position
    98                                  
    99                                       ; Apply memory-loaded icon
   100 000000BE 488B3C25[C3180000]           mov        rdi, qword [window.handle]
   101 000000C6 488B3425[02190000]           mov        rsi, qword [pixbuffer]
   102 000000CE E8(00000000)                 call       gtk_window_set_icon
   103                                  
   104                                       ; Connect Window Destroy Signal
   105 000000D3 4531C9                       xor        r9d, r9d
   106 000000D6 4531C0                       xor        r8d, r8d
   107 000000D9 488B0C25[C3180000]           mov        rcx, qword [window.handle]
   108 000000E1 48BA-                        mov        rdx, gtk_main_quit
   108 000000E3 [0000000000000000] 
   109 000000EB 48BE-                        mov        rsi, signal.destroy
   109 000000ED [EA18000000000000] 
   110 000000F5 488B3C25[C3180000]           mov        rdi, qword [window.handle]
   111 000000FD E8(00000000)                 call       g_signal_connect_data
   112                                  
   113                                       ; Create Fixed Container layout block
   114 00000102 E8(00000000)                 call       gtk_fixed_new
   115 00000107 48890425[D5180000]           mov        qword [fixed.handle], rax
   116                                  
   117 0000010F 488B3C25[C3180000]           mov        rdi, qword [window.handle]
   118 00000117 488B3425[D5180000]           mov        rsi, qword [fixed.handle]
   119 0000011F E8(00000000)                 call       gtk_container_add
   120                                  
   121                                       ; -------------------------------------------------------------------------
   122                                       ; 4. Instantiate Button Control Component
   123                                       ; -------------------------------------------------------------------------
   124 00000124 48BF-                        mov        rdi, button.caption
   124 00000126 [E518000000000000] 
   125 0000012E E8(00000000)                 call       gtk_button_new_with_label
   126 00000133 48890425[DD180000]           mov        qword [button.handle], rax
   127                                  
   128                                       ; Apply explicit button layout size dimensions
   129 0000013B 488B3C25[DD180000]           mov        rdi, qword [button.handle]
   130 00000143 BE50000000                   mov        rsi, 80
   131 00000148 BA23000000                   mov        rdx, 35
   132 0000014D E8(00000000)                 call       gtk_widget_set_size_request
   133                                  
   134                                       ; Connect Clicked Signal to close main loop
   135 00000152 4531C9                       xor        r9d, r9d
   136 00000155 4531C0                       xor        r8d, r8d
   137 00000158 488B0C25[C3180000]           mov        rcx, qword [window.handle]
   138 00000160 48BA-                        mov        rdx, gtk_main_quit
   138 00000162 [0000000000000000] 
   139 0000016A 48BE-                        mov        rsi, signal.clicked
   139 0000016C [F218000000000000] 
   140 00000174 488B3C25[DD180000]           mov        rdi, qword [button.handle]
   141 0000017C E8(00000000)                 call       g_signal_connect_data
   142                                  
   143                                       ; Pack button into the fixed layout manager container at coordinates (50, 50)
   144 00000181 488B3C25[D5180000]           mov        rdi, qword [fixed.handle]
   145 00000189 488B3425[DD180000]           mov        rsi, qword [button.handle]
   146 00000191 BA32000000                   mov        rdx, 50                   ; x-coordinate
   147 00000196 B932000000                   mov        rcx, 50                   ; y-coordinate
   148 0000019B E8(00000000)                 call       gtk_fixed_put
   149                                  
   150                                       ; Render all active layout elements
   151 000001A0 488B3C25[C3180000]           mov        rdi, qword [window.handle]
   152 000001A8 E8(00000000)                 call       gtk_widget_show_all
   153                                  
   154 000001AD E8(00000000)                 call       gtk_main
   155                                  
   156                                  Exit:
   157 000001B2 4831FF                       xor        rdi, rdi                  ; Exit code = 0
   158 000001B5 E8(00000000)                 call       exit
