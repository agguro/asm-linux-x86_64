   119                                       ; 4. Pack Buttons and Connect Signals
   120                                       %macro pack_button 1
   121                                          mov     rdi, qword [vbox.handle]
   122                                          mov     rsi, qword [%1.handle]
   123                                          mov     rdx, TRUE
   124                                          mov     rcx, TRUE
   125                                          xor     r8d, r8d
   126                                          call    gtk_box_pack_start
   127                                  
   128                                          xor     r9d, r9d
   129                                          xor     r8d, r8d
   130                                          mov     rcx, qword [window.handle]
   131                                          mov     rdx, on_button_clicked
   132                                          mov     rsi, signal.clicked
   133                                          mov     rdi, qword [%1.handle]
   134                                          call    g_signal_connect_data
   135                                       %endmacro
