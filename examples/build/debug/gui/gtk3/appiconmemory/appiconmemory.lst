     1                                  ; ==============================================================================
     2                                  ; Name        : appiconmemory.asm
     3                                  ; Author      : Roberto Aguas Guerreiro [agguro]
     4                                  ; Derived From: ZetCode GTK3 Examples
     5                                  ; Description : Setting an application icon from memory and display the same 
     6                                  ;               icon as image in a window
     7                                  ; ABI Status  : Stack-aligned (Original working configuration)
     8                                  ; ==============================================================================
     9                                  
    10                                  bits 64
    11                                  
    12                                  [list -]
    21                                  
    22                                  section .data
    23 00000000 <bin 18C3h>                  logo:          incbin    "../resources/pictures/logo.png"
    24                                       .size:         equ       $ - logo
    25                                  
    26                                       window:
    27 000018C3 0000000000000000             .handle:       dq        0
    28 000018CB 77696E646F77207769-          .title:        db        "window with application icon",0
    28 000018D4 7468206170706C6963-
    28 000018DD 6174696F6E2069636F-
    28 000018E6 6E00               
    29 000018E8 61707069636F6E6D65-          .class:        db        "appiconmemory",0
    29 000018F1 6D6F727900         
    30                                  
    31                                       signal:
    32 000018F6 64657374726F7900             .destroy:      db        "destroy",0
    33                                  
    34 000018FE 0000000000000000             loader:        dq        0
    35 00001906 0000000000000000             pixbuffer:     dq        0
    36 0000190E 0000000000000000             image:         dq        0
    37                                  
    38                                  section .text
    39                                       global _start
    40                                  
    41                                  _start:
    42                                       ; -------------------------------------------------------------------------
    43                                       ; 1. Retrieve argc/argv and enforce System V AMD64 ABI Stack Alignment
    44                                       ; -------------------------------------------------------------------------
    45 00000000 488B3C24                     mov      rdi, [rsp]                ; argc
    46 00000004 488D742408                   lea      rsi, [rsp + 8]            ; argv
    47                                  
    48 00000009 4989FC                       mov      r12, rdi                  ; Back-up argc
    49 0000000C 4989F5                       mov      r13, rsi                  ; Back-up argv
    50                                  
    51 0000000F 4883E4F0                     and      rsp, -16                  ; Enforce 16-byte alignment
    52 00000013 4883EC10                     sub      rsp, 16                   ; Reserved space for &argc and &argv
    53                                  
    54 00000017 488D3C24                     lea      rdi, [rsp]                ; Move &argc to stack
    55 0000001B 4C8927                       mov      [rdi], r12
    56 0000001E 488D742408                   lea      rsi, [rsp + 8]            ; Move &argv to stack
    57 00000023 4C892E                       mov      [rsi], r13
    58                                  
    59 00000026 E8(00000000)                 call     gtk_init
    60                                  
    61                                       ; Set application ID for desktop environment matching
    62 0000002B 48BF-                        mov      rdi, window.class
    62 0000002D [E818000000000000] 
    63 00000035 E8(00000000)                 call     g_set_prgname
    64                                  
    65                                       ; -------------------------------------------------------------------------
    66                                       ; 2. Generate Pixbuf from Embedded Asset in RAM
    67                                       ; -------------------------------------------------------------------------
    68 0000003A E8(00000000)                 call     gdk_pixbuf_loader_new
    69 0000003F 48890425[FE180000]           mov      qword [loader], rax
    70                                  
    71 00000047 488B3C25[FE180000]           mov      rdi, qword [loader]
    72 0000004F 48BE-                        mov      rsi, logo
    72 00000051 [0000000000000000] 
    73 00000059 BAC3180000                   mov      rdx, logo.size            ; Pass size as 64-bit value
    74 0000005E 4831C9                       xor      rcx, rcx                  ; GError** = NULL
    75 00000061 E8(00000000)                 call     gdk_pixbuf_loader_write
    76                                  
    77 00000066 488B3C25[FE180000]           mov      rdi, qword [loader]
    78 0000006E E8(00000000)                 call     gdk_pixbuf_loader_get_pixbuf
    79 00000073 48890425[06190000]           mov      qword [pixbuffer], rax
    80                                  
    81                                       ; -------------------------------------------------------------------------
    82                                       ; 3. Build Window & Image Components
    83                                       ; -------------------------------------------------------------------------
    84 0000007B BF00000000                   mov      rdi, GTK_WINDOW_TOPLEVEL
    85 00000080 E8(00000000)                 call     gtk_window_new
    86 00000085 48890425[C3180000]           mov      qword [window.handle], rax
    87                                  
    88                                       ; Map Window Manager Class for taskbar matching (KDE/Wayland fallback)
    89 0000008D 488B3C25[C3180000]           mov      rdi, qword [window.handle]
    90 00000095 48BE-                        mov      rsi, window.class
    90 00000097 [E818000000000000] 
    91 0000009F 48BA-                        mov      rdx, window.class
    91 000000A1 [E818000000000000] 
    92 000000A9 E8(00000000)                 call     gtk_window_set_wmclass
    93                                  
    94                                       ; Create GTK Image component from RAM-based pixbuf
    95 000000AE 488B3C25[06190000]           mov      rdi, qword [pixbuffer]
    96 000000B6 E8(00000000)                 call     gtk_image_new_from_pixbuf
    97 000000BB 48890425[0E190000]           mov      qword [image], rax
    98                                  
    99                                       ; Pack image into the main window container
   100 000000C3 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   101 000000CB 488B3425[0E190000]           mov      rsi, qword [image]
   102 000000D3 E8(00000000)                 call     gtk_container_add
   103                                  
   104                                       ; Set Window Properties
   105 000000D8 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   106 000000E0 48BE-                        mov      rsi, window.title
   106 000000E2 [CB18000000000000] 
   107 000000EA E8(00000000)                 call     gtk_window_set_title
   108                                  
   109 000000EF 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   110 000000F7 BEE6000000                   mov      rsi, 230
   111 000000FC BA96000000                   mov      rdx, 150
   112 00000101 E8(00000000)                 call     gtk_window_set_default_size
   113                                  
   114 00000106 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   115 0000010E BE01000000                   mov      rsi, GTK_WIN_POS_CENTER
   116 00000113 E8(00000000)                 call     gtk_window_set_position
   117                                  
   118                                       ; Set runtime window icon decoration
   119 00000118 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   120 00000120 488B3425[06190000]           mov      rsi, qword [pixbuffer]
   121 00000128 E8(00000000)                 call     gtk_window_set_icon
   122                                  
   123                                       ; -------------------------------------------------------------------------
   124                                       ; 4. Signals & Event Loop
   125                                       ; -------------------------------------------------------------------------
   126 0000012D 4531C9                       xor      r9d, r9d                  ; GConnectFlags = 0
   127 00000130 4531C0                       xor      r8d, r8d                  ; GClosureNotify = NULL
   128 00000133 4831C9                       xor      rcx, rcx                  ; user_data = NULL
   129 00000136 48BA-                        mov      rdx, gtk_main_quit
   129 00000138 [0000000000000000] 
   130 00000140 48BE-                        mov      rsi, signal.destroy
   130 00000142 [F618000000000000] 
   131 0000014A 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   132 00000152 E8(00000000)                 call     g_signal_connect_data
   133                                  
   134                                       ; Show window and all child elements
   135 00000157 488B3C25[C3180000]           mov      rdi, qword [window.handle]
   136 0000015F E8(00000000)                 call     gtk_widget_show_all
   137                                  
   138 00000164 E8(00000000)                 call     gtk_main
   139                                  
   140                                  .L_exit:
   141 00000169 4831FF                       xor      rdi, rdi
   142 0000016C E8(00000000)                 call     exit
