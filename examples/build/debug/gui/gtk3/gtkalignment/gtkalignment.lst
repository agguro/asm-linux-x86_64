   139 0000014D 488B3425[20000000]           mov        rsi, qword [bttnClose.handle]
   140 00000155 4831D2                       xor        rdx, rdx
   141 00000158 4831C9                       xor        rcx, rcx
   142 0000015B 4531C0                       xor        r8d, r8d
   143 0000015E E8(00000000)                 call       gtk_box_pack_start
