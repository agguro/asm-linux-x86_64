   147                                       ; -------------------------------------------------------------------------
   148 00000163 488B3C25[4E000000]           mov        rdi, qword [halign.handle]
   149 0000016B 488B3425[3E000000]           mov        rsi, qword [hbox.handle]
   150 00000173 E8(00000000)                 call       gtk_container_add
