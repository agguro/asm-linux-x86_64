    55                                  _start:
    56                                       ; -------------------------------------------------------------------------
    57                                       ; 1. Stack Alignment conform System V AMD64 ABI
    58                                       ; -------------------------------------------------------------------------
    59 00000000 488B3C24                     mov        rdi, [rsp]                ; argc
    60 00000004 488D742408                   lea        rsi, [rsp + 8]            ; argv
    61 00000009 4989FC                       mov        r12, rdi
    62 0000000C 4989F5                       mov        r13, rsi
    63                                  
    64 0000000F 4883E4F0                     and        rsp, -16
    65 00000013 4883EC10                     sub        rsp, 16
    66 00000017 488D3C24                     lea        rdi, [rsp]
    67 0000001B 4C8927                       mov        [rdi], r12
    68 0000001E 488D742408                   lea        rsi, [rsp + 8]
    69 00000023 4C892E                       mov        [rsi], r13
    70                                  
    71 00000026 E8(00000000)                 call       gtk_init
    72                                  
    73                                       ; -------------------------------------------------------------------------
    74                                       ; 2. Build Structural Containers
    75                                       ; -------------------------------------------------------------------------
    76 0000002B BF00000000                   mov        rdi, GTK_WINDOW_TOPLEVEL
    77 00000030 E8(00000000)                 call       gtk_window_new
    78 00000035 48890425[00000000]           mov        qword [window.handle], rax
    79                                  
    80                                       ; Top-level vertical layout box
    81 0000003D BF01000000                   mov        rdi, GTK_ORIENTATION_VERTICAL
    82 00000042 4831F6                       xor        rsi, rsi
    83 00000045 E8(00000000)                 call       gtk_box_new
    84 0000004A 48890425[36000000]           mov        qword [vbox.handle], rax
    85                                  
    86                                       ; Horizontal button rows pack box
    87 00000052 BF00000000                   mov        rdi, GTK_ORIENTATION_HORIZONTAL
    88 00000057 BE05000000                   mov        rsi, 5                    ; Spacing between buttons = 5px
    89 0000005C E8(00000000)                 call       gtk_box_new
    90 00000061 48890425[3E000000]           mov        qword [hbox.handle], rax
    91                                  
    92                                       ; Vertical alignment (xalign=0.0, yalign=1.0 [Bottom], xscale=1.0, yscale=0.0)
    93 00000069 F30F100425-                  movss      xmm0, dword [float_0]
    93 0000006E [56000000]         
    94 00000072 F30F100C25-                  movss      xmm1, dword [float_1]
    94 00000077 [5A000000]         
    95 0000007B F30F101425-                  movss      xmm2, dword [float_1]
    95 00000080 [5A000000]         
    96 00000084 F30F101C25-                  movss      xmm3, dword [float_0]
    96 00000089 [56000000]         
    97 0000008D E8(00000000)                 call       gtk_alignment_new
    98 00000092 48890425[46000000]           mov        qword [valign.handle], rax
    99                                  
