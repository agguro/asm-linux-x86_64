   101 0000009A F30F100425-                  movss      xmm0, dword [float_1]
   101 0000009F [5A000000]         
   102 000000A3 F30F100C25-                  movss      xmm1, dword [float_0]
   102 000000A8 [56000000]         
   103 000000AC F30F101425-                  movss      xmm2, dword [float_0]
