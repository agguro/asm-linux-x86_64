    44                                       ; 1. Retrieve argc/argv and enforce System V AMD64 ABI Stack Alignment
    45                                       ; -------------------------------------------------------------------------
    46 00000000 488B3C24                     mov        rdi, [rsp]                ; argc
    47 00000004 488D742408                   lea        rsi, [rsp + 8]            ; argv
    48                                  
    49 00000009 4989FC                       mov        r12, rdi                  ; Back-up argc
    50 0000000C 4989F5                       mov        r13, rsi                  ; Back-up argv
    51                                  
    52 0000000F 4883E4F0                     and        rsp, -16                  ; Enforce 16-byte alignment
    53 00000013 4883EC10                     sub        rsp, 16                   ; Reserved space for &argc and &argv
    54                                  
    55 00000017 488D3C24                     lea        rdi, [rsp]                ; Move &argc to stack
