    10 00000000 ????????????????            .unknown1:              resq    1   ;  0 XExtData* hook for extension to hang data
    11 00000008 ????????????????            .private1:              resq    1   ;  8 struct _XPrivate*
    12 00000010 ????????                    .fd:                    resd    1   ; 10 int Network socket
    13 00000014 ????????                    .private2:              resd    1   ; 14 int
    14 00000018 ????????                    .proto_major_version:   resd    1   ; 18 int - major version of server's X protocol
    15 0000001C ????????                    .proto_minor_version:   resd    1   ; 1C int - minor version of servers X protocol
    16 00000020 ????????????????            .vendor:                resq    1   ; 20 char* - vendor of the server hardware
    17 00000028 ????????????????            .private3:              resq    1   ; 28 XID
    18 00000030 ????????????????            .private4:              resq    1   ; 30 XID
    19 00000038 ????????????????            .private5:              resq    1   ; 38 XID
    20 00000040 ????????                    .private6:              resd    1   ; 40 int
    21 00000044 ????????????????            .resource_alloc:        resq    1   ; 44 XID - allocator function struct _XDisplay*
    22 0000004C ????????                    .byte_order:            resd    1   ; 4C int - screen byte order, LSBFirst, MSBFirst 
    23 00000050 ????????                    .bitmap_unit:           resd    1   ; 50 int - padding and data requirements
    24 00000054 ????????                    .bitmap_pad:            resd    1   ; 54 int - padding requirements on bitmaps
    25 00000058 ????????                    .bitmap_bit_order:      resd    1   ; 58 int - LeastSignificant or MostSignificant
    26 0000005C ????????                    .nformats:              resd    1   ; 5C int - number of pixmap formats in list
    27 00000060 ????????????????            .pixmap_format:         resq    1   ; 60 ScreenFormat* - pixmap format list
    28 00000068 ????????                    .private8:              resd    1   ; 68 int
    29 0000006C ????????                    .release:               resd    1   ; 6C int release of the server
    30 00000070 ????????????????            .private9:              resq    1   ; 70 struct _XPrivate*
    31 00000078 ????????????????            .private10:             resq    1   ; 78 struct _XPrivate*
    32 00000080 ????????                    .qlen:                  resd    1   ; 80 Length of input event queue
    33 00000084 ????????????????            .last_request_read:     resq    1   ; 84 seq number of last event read
    34 0000008C ????????????????            .request:               resq    1   ; 8C sequence number of last request
    35 00000094 ????????????????            .private11:             resq    1   ; 94 XPointer
    36 0000009C ????????????????            .private12:             resq    1   ; 9C XPointer
    37 000000A4 ????????????????            .private13:             resq    1   ; A4 XPointer
    38 000000AC ????????????????            .private14:             resq    1   ; AC XPointer
    39 000000B4 ????????                    .max_request_size:      resd    1   ; B4 maximum number 32 bit words in request
    40 000000B8 ????????????????            .db:                    resq    1   ; B8 struct _XrmHashBucketRec*
    41 000000C0 ????????????????            .private15:             resq    1   ; C0 int* - struct _XDisplay*
    42 000000C8 ????????????????            .display_name:          resq    1   ; C8 char* - "host:display" string used on this connect
    43 000000D0 ????????                    .default_screen:        resd    1   ; D0 int - default screen for operations
    44 000000D4 ????????                    .nscreens:              resd    1   ; D4 int - number of screens on this server
    45 000000D8 ????????????????            .screens:               resq    1   ; D8 Screen* - pointer to list of screens
    46 000000E0 ????????????????            .motion_buffer:         resq    1   ; E0 size of motion buffer
    47 000000E8 ????????????????            .private16:             resq    1   ; E8
    48 000000F0 ????????                    .min_keycode:           resd    1   ; F0 minimum defined keycode
    49 000000F4 ????????                    .max_keycode:           resd    1   ; F4 maximum defined keycode
    50 000000F8 ????????????????            .private17:             resq    1   ; F8 XPointer
    51 00000100 ????????????????            .private18:             resq    1   ; 100 XPointer
    52 00000108 ????????                    .private19:             resd    1   ; 108 int
    53 0000010C ????????????????            .xdefaults:             resq    1   ; 10C char* - contents of defaults from server
    54                                      ;there is more to this structure, but it is private to Xlib
    55                                  endstruc
