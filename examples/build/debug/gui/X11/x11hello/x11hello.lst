    57                                  struc SCREEN
    58 00000000 ????????????????            .ext_data:          resq    1   ;XExtData* - hook for extension to hang data
    59 00000008 ????????????????            .display:           resq    1   ;struct _XDisplay* - back pointer to display structure
    60 00000010 ????????????????            .root:              resq    1   ;Window - Root window id.
    61 00000018 ????????                    .width:             resd    1   ;int - width of screen
    62 0000001C ????????                    .height:            resd    1   ;int - height of screen
    63 00000020 ????????                    .mwidth:            resd    1   ;int width of  in millimeters
    64 00000024 ????????                    .mheight:           resd    1   ;int height of  in millimeters
    65 00000028 ????????                    .ndepths:           resd    1   ;int - number of depths possible
    66 0000002C ????????????????            .depths:            resq    1   ;Depth* - list of allowable depths on the screen
    67 00000034 ????????                    .root_depth:        resd    1   ;int - bits per pixel
    68 00000038 ????????????????            .root_visual:       resq    1   ;Visual* - root visual
    69 00000040 ????????????????            .default_gc:        resq    1   ;GC - GC for the root root visual
    70 00000048 ????????????????            .cmap:              resq    1   ;Colormap - default color map
    71 00000050 ????????????????            .white_pixel:       resq    1   ;unsigned long - White pixel values
    72 00000058 ????????????????            .black_pixel:       resq    1   ;unsigned long - Black pixel values
    73 00000060 ????????                    .max_maps:          resd    1   ;int - max color maps
    74 00000064 ????????                    .min_maps:          resd    1   ;int - min color maps
    75 00000068 ????????                    .backing_store:     resd    1   ;int - Never, WhenMapped, Always
    76 0000006C ????????                    .save_unders:       resd    1   ;Bool
    77 00000070 ????????                    .root_input_mask:   resd    1   ;long - initial root input mask
    78                                  endstruc
