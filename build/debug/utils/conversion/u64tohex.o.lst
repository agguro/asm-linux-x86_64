GAS LISTING utils/conversion/u64tohex.s 			page 1


   1              	/* **************************************************************************
   2              	 * Name         : u64tohex.s
   3              	 * Assemble     : as --64 u64tohex.s -o u64tohex.o
   4              	 * Description  : Converts a 64-bit unsigned integer to a Hex string.
   5              	 *
   6              	 * Input        : RDI = value, RSI = start of buffer, RDX = buffer len
   7              	 * Output       : RAX = 0 (success) or 1 (overflow)
   8              	 * Registers    : RDI = unchanged
   9              	 * RSI = pointer to start of hex digits (including 0x)
  10              	 * RDX = actual length (including 0x)
  11              	 *
  12              	 * Strategy:
  13              	 * This function fills the buffer from right to left. By starting at the end 
  14              	 * of the buffer and moving backwards, the digits naturally end up in the 
  15              	 * correct order without requiring a separate "string reverse" pass. It then
  16              	 * prepends the "0x" prefix if space permits.
  17              	 * ************************************************************************** */
  18              	
  19              	.section .text
  20              	.globl u64tohex
  21              	.type u64tohex, @function
  22              	
  23              	u64tohex:
  24 0000 55       	    pushq   %rbp                
  25 0001 4889E5   	    movq    %rsp, %rbp      
  26              	
  27 0004 488D0C16 	    leaq    (%rsi, %rdx), %rcx      # End of buffer
  28 0008 4989C9   	    movq    %rcx, %r9               # Save for length math
  29 000b 4889F8   	    movq    %rdi, %rax              
  30              	
  31              	    # --- Main Hex Loop ---
  32              	1:
  33 000e 48FFC9   	    decq    %rcx
  34 0011 4839F1   	    cmpq    %rsi, %rcx              
  35 0014 7C3E     	    jl      3f                      # Overflow: buffer too small
  36              	
  37 0016 4989C0   	    movq    %rax, %r8
  38 0019 4983E00F 	    andq    $0xF, %r8               # Isolate last 4 bits (one hex digit)
  39              	
  40 001d 4180F80A 	    cmpb    $10, %r8b
  41 0021 7C06     	    jl      2f                      # If 0-9
  42 0023 4180C037 	    addb    $('A' - 10), %r8b       # If A-F
  43 0027 EB04     	    jmp     4f                      
  44              	
  45              	2:
  46 0029 4180C030 	    addb    $'0', %r8b              
  47              	
  48              	4:
  49 002d 448801   	    movb    %r8b, (%rcx)            
  50 0030 48C1E804 	    shrq    $4, %rax                # Shift to next nibble (4 bits)
  51 0034 75D8     	    jnz     1b                      # Continue if value remains
  52              	
  53              	    # --- Add "0x" Prefix ---
  54 0036 4883E902 	    subq    $2, %rcx                # Need 2 bytes for '0' and 'x'
  55 003a 4839F1   	    cmpq    %rsi, %rcx
  56 003d 7C15     	    jl      3f                      # Trigger overflow if no room for prefix
  57              	
GAS LISTING utils/conversion/u64tohex.s 			page 2


  58 003f C60130   	    movb    $'0', (%rcx)            # Store prefix '0'
  59 0042 C6410178 	    movb    $'x', 1(%rcx)           # Store prefix 'x'
  60              	
  61              	    # --- Success Exit ---
  62 0046 4C89CA   	    movq    %r9, %rdx
  63 0049 4829CA   	    subq    %rcx, %rdx              # Calculate final length
  64 004c 4889CE   	    movq    %rcx, %rsi              # Update RSI to start of "0x"
  65 004f 4831C0   	    xorq    %rax, %rax              # Return 0 (success)
  66 0052 5D       	    popq    %rbp                    
  67 0053 C3       	    ret
  68              	
  69              	3:  # --- Error Exit ---
  70 0054 48C7C001 	    movq    $1, %rax                # Return 1 (Overflow)
  70      000000
  71 005b 5D       	    popq    %rbp                    
  72 005c C3       	    ret
  73              	
  74              	.size u64tohex, .-u64tohex
  75              	.section .note.GNU-stack,"",@progbits
