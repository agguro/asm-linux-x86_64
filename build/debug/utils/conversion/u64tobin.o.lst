   1              	/* **************************************************************************
   2              	 * Name         : u64tobin.s
   3              	 * Assemble     : as --64 u64tobin.s -o u64tobin.o
   4              	 * Description  : Converts a 64-bit integer to a binary bitstring.
   5              	 *
   6              	 * Input        : %rdi = value
   7              	 * %rsi = buffer (minimum 65 bytes)
   8              	 * %rdx = mode (0=trim, -1=auto, >0=fixed width)
   9              	 * Output       : %rax = pointer to start of string in buffer
  10              	 * %rdx = width of the string used
  11              	 *
  12              	 * Strategy:
  13              	 * The function utilizes the 'shlq' and 'adcb' pattern. By shifting the MSB 
  14              	 * into the carry flag and adding that flag to the ASCII value of '0', we 
  15              	 * generate bits without conditional branching in the main loop.
  16              	 * ************************************************************************** */
  17              	
  18              	.section .text
  19              	.globl u64tobin
  20              	.type u64tobin, @function
  21              	
  22              	u64tobin:
  23 0000 55       	    pushq   %rbp
  24 0001 4889E5   	    movq    %rsp, %rbp
  25 0004 53       	    pushq   %rbx
  26 0005 51       	    pushq   %rcx
  27 0006 56       	    pushq   %rsi            # [rbp-24] Save original buffer start
  28              	
  29              	    # 1. Handle Auto-Detect Mode
  30 0007 4883FAFF 	    cmpq    $-1, %rdx
  31 000b 751A     	    jne     .Lcheck_trim
  32 000d F3480FBD 	    lzcntq  %rdi, %rcx      # Get number of leading zeros
  32      CF
  33 0012 48C7C240 	    movq    $64, %rdx
  33      000000
  34 0019 4829CA   	    subq    %rcx, %rdx      # Width = 64 - zeros
  35 001c 750E     	    jnz     .Lconvert
  36 001e 48C7C201 	    movq    $1, %rdx        # If value is 0, width is 1
  36      000000
  37 0025 EB05     	    jmp     .Lconvert
  38              	
  39              	.Lcheck_trim:
  40 0027 4885D2   	    testq   %rdx, %rdx
  41 002a 7500     	    jnz     .Lconvert
  42              	    # Mode 0 (trim) logic is processed after conversion loop
  43              	
  44              	.Lconvert:
  45 002c 52       	    pushq   %rdx            # [rbp-32] Store target width
  46 002d 4889F8   	    movq    %rdi, %rax      # Load value
  47 0030 4889F7   	    movq    %rsi, %rdi      # Set write pointer
  48 0033 48C7C140 	    movq    $64, %rcx       # Loop counter
  48      000000
  49 003a 4831DB   	    xorq    %rbx, %rbx      # Reset 'first 1' pointer
  50              	
  51              	
  52              	
  53              	.Lloop:
GAS LISTING utils/conversion/u64tobin.s 			page 2


  54 003d 4531C0   	    xorl    %r8d, %r8d
  55 0040 48D1E0   	    shlq    $1, %rax        # Shift MSB into Carry Flag
  56 0043 4180D030 	    adcb    $'0', %r8b      # ASCII '0' + Carry
  57 0047 448807   	    movb    %r8b, (%rdi)    # Store bit
  58              	    
  59 004a 4180F831 	    cmpb    $'1', %r8b
  60 004e 7508     	    jne     .Lnext
  61 0050 4885DB   	    testq   %rbx, %rbx
  62 0053 7503     	    jnz     .Lnext
  63 0055 4889FB   	    movq    %rdi, %rbx      # Capture pointer to first '1'
  64              	
  65              	.Lnext:
  66 0058 48FFC7   	    incq    %rdi
  67 005b E2E0     	    loop    .Lloop
  68 005d C60700   	    movb    $0, (%rdi)      # Null terminator
  69              	
  70              	    # --- Result Calculation ---
  71 0060 5A       	    popq    %rdx            # Restore target width
  72 0061 488B75E8 	    movq    -24(%rbp), %rsi # Restore original buffer start
  73              	
  74 0065 4885D2   	    testq   %rdx, %rdx
  75 0068 740F     	    jz      .Ltrim_logic    # If mode 0, find first '1'
  76              	
  77              	    # Fixed Width: Start = BufferStart + (64 - Width)
  78 006a 48C7C040 	    movq    $64, %rax
  78      000000
  79 0071 4829D0   	    subq    %rdx, %rax
  80 0074 4801F0   	    addq    %rsi, %rax      # Calculate final start pointer
  81 0077 EB1C     	    jmp     .Lexit
  82              	
  83              	.Ltrim_logic:
  84 0079 4885DB   	    testq   %rbx, %rbx
  85 007c 750D     	    jnz     .Lfound_one
  86 007e 488D463F 	    leaq    63(%rsi), %rax  # Pointer to the last '0'
  87 0082 48C7C201 	    movq    $1, %rdx
  87      000000
  88 0089 EB0A     	    jmp     .Lexit
  89              	
  90              	.Lfound_one:
  91 008b 4889D8   	    movq    %rbx, %rax      # Pointer to first '1'
  92 008e 488D5640 	    leaq    64(%rsi), %rdx
  93 0092 4829DA   	    subq    %rbx, %rdx      # Calculate effective width
  94              	
  95              	.Lexit:
  96 0095 5E       	    popq    %rsi            # Restore caller's RSI
  97 0096 59       	    popq    %rcx
  98 0097 5B       	    popq    %rbx
  99 0098 5D       	    popq    %rbp
 100 0099 C3       	    ret
