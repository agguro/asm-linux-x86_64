GAS LISTING utils/conversion/u64toa.s 			page 1


   1              	/* **************************************************************************
   2              	 * Name         : u64toa.s
   3              	 * Assemble     : as --64 u64toa.s -o u64toa.o
   4              	 * Description  : Converts a 64-bit unsigned integer to a decimal string.
   5              	 *
   6              	 * Input        : RDI = value, RSI = start of buffer, RDX = buffer len
   7              	 * Output       : RAX = 0 (success) or 1 (overflow)
   8              	 * Registers    : RDI = unchanged
   9              	 * RSI = pointer to start of digits
  10              	 * RDX = actual length
  11              	 *
  12              	 * Strategy:
  13              	 * This function performs division by 10 using a reciprocal multiplication
  14              	 * (Magic Number: 0xCCCCCCCCCCCCCCCD). This is significantly faster than
  15              	 * the hardware 'div' instruction. The buffer is filled from right to left.
  16              	 * ************************************************************************** */
  17              	
  18              	.section .text
  19              	.globl u64toa
  20              	.type u64toa, @function
  21              	
  22              	u64toa:
  23              	    # --- Prologue ---
  24 0000 55       	    pushq   %rbp                    # Save caller's frame pointer
  25 0001 4889E5   	    movq    %rsp, %rbp              # Establish stack frame
  26              	
  27              	    # --- Setup ---
  28 0004 488D0C16 	    leaq    (%rsi, %rdx), %rcx      # %rcx = End of buffer (writing backwards)
  29 0008 4989C9   	    movq    %rcx, %r9               # Save end address for length math
  30 000b 4889F8   	    movq    %rdi, %rax              # %rax = working copy of the value
  31 000e 49B8CDCC 	    movabsq $0xCCCCCCCCCCCCCCCD, %r8 # Magic number for division by 10
  31      CCCCCCCC 
  31      CCCC
  32              	
  33              	    # --- Conversion Loop ---
  34              	1:
  35 0018 48FFC9   	    decq    %rcx
  36 001b 4839F1   	    cmpq    %rsi, %rcx              # Buffer overflow check
  37 001e 7C31     	    jl      2f                      # If %rcx < start, jump to error
  38              	
  39              	
  40              	
  41 0020 4989C3   	    movq    %rax, %r11              # %r11 = temporary copy for modulo
  42 0023 49F7E0   	    mulq    %r8                     # High 64 bits of result in %rdx
  43 0026 48C1EA03 	    shrq    $3, %rdx                # %rdx = quotient (value / 10)
  44              	    
  45              	    # Modulo: %r11 = value - (quotient * 10)
  46 002a 4C8D1492 	    leaq    (%rdx, %rdx, 4), %r10   # %r10 = quotient * 5
  47 002e 49D1E2   	    shlq    $1, %r10                # %r10 = quotient * 10
  48 0031 4D29D3   	    subq    %r10, %r11              # %r11 = digit (0-9)
  49              	    
  50              	    # Convert to ASCII and store
  51 0034 4180C330 	    addb    $'0', %r11b
  52 0038 448819   	    movb    %r11b, (%rcx)
  53              	    
  54 003b 4889D0   	    movq    %rdx, %rax              # Prepare quotient for next iteration
  55 003e 4885C0   	    testq   %rax, %rax              # Is quotient zero?
GAS LISTING utils/conversion/u64toa.s 			page 2


  56 0041 75D5     	    jnz     1b                      # If not, loop back
  57              	
  58              	    # --- Success Exit ---
  59 0043 4C89CA   	    movq    %r9, %rdx
  60 0046 4829CA   	    subq    %rcx, %rdx              # %rdx = actual length
  61 0049 4889CE   	    movq    %rcx, %rsi              # %rsi = pointer to the first digit
  62 004c 4831C0   	    xorq    %rax, %rax              # Return status 0 (Success)
  63              	    
  64 004f 5D       	    popq    %rbp                    # Epilogue
  65 0050 C3       	    ret
  66              	
  67              	    # --- Error Path ---
  68              	2:
  69 0051 48C7C001 	    movq    $1, %rax                # Return status 1 (Overflow)
  69      000000
  70 0058 5D       	    popq    %rbp                    # Epilogue
  71 0059 C3       	    ret
  72              	
  73              	.size u64toa, .-u64toa    
  74              	.section .note.GNU-stack,"",@progbits
