GAS LISTING utils/hackers_delight/hacker_nibble2hexascii.s 			page 1


   1              	# -----------------------------------------------------------------------------
   2              	# Name:        hacker_nibble2hexascii
   3              	# Author:      Hacker's Delight Style (Henry S. Warren Jr. inspiration)
   4              	# Description: Converts a 64-bit GPR to 16 Hex-ASCII characters.
   5              	# Logic:       Branchless SBB trick (no lookup table, no memory access).
   6              	# C Prototype: extern "C" void hacker_nibble2hex(uint64_t val, char* buf);
   7              	# -----------------------------------------------------------------------------
   8              	
   9              	    .section .text
  10              	    .global hacker_nibble2hexascii
  11              	    .type   hacker_nibble2hexascii, @function
  12              	
  13              	hacker_nibble2hexascii:
  14              	    # RDI = input value (64-bit)
  15              	    # RSI = destination buffer (must be at least 16 bytes)
  16              	
  17 0000 48C7C110 	    mov     $16, %rcx                 # 16 nibbles in a 64-bit register
  17      000000
  18              	
  19              	.L_hexloop:
  20 0007 48C1C704 	    rol     $4, %rdi                  # rotate next nibble into low bits
  21 000b 4088F8   	    mov     %dil, %al                 # copy low byte
  22 000e 240F     	    and     $0x0F, %al                # isolate nibble (0–15)
  23              	
  24              	    # --- Hacker's Delight branchless hex conversion ---
  25 0010 3C0A     	    cmp     $10, %al                  # CF = (AL < 10)
  26 0012 1C69     	    sbb     $0x69, %al                # AL = AL - 0x69 - CF
  27 0014 241F     	    and     $0x1F, %al                # keep low 5 bits
  28 0016 0420     	    add     $0x20, %al                # normalize to ASCII ('0'–'9','A'–'F')
  29              	    # --------------------------------------------------
  30              	
  31 0018 8806     	    mov     %al, (%rsi)               # store ASCII char
  32 001a 48FFC6   	    inc     %rsi                      # advance buffer pointer
  33 001d E2E8     	    loop    .L_hexloop                # RCX--, continue if not zero
  34              	
  35 001f C3       	    ret
  36              	
  37              	.size hacker_nibble2hexascii, . - hacker_nibble2hexascii
  38              	
  39              	.section .note.GNU-stack,"",@progbits
