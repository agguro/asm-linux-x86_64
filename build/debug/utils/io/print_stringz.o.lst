GAS LISTING utils/io/print_stringz.s 			page 1


   1              	/* 
   2              	 ***************************************************************************
   3              	 * Name         : print_stringz.s
   4              	 * Assemble     : as --64 print_stringz.s -o print_stringz.o
   5              	 * Description  : Prints a NULL-terminated string to a specified FD.
   6              	 *
   7              	 * Input        : %rdi = File Descriptor (1=stdout, 2=stderr)
   8              	 * %rsi = Pointer to NULL-terminated string
   9              	 * Output       : None (Registers are restored)
  10              	 *
  11              	 * Strategy:
  12              	 * This function is "ABI Transparent." It saves every register that could 
  13              	 * potentially be changed by a function call (strlen) or a Linux syscall 
  14              	 * (write). This allows the caller to use it without worrying about losing
  15              	 * data in volatile registers like %rax, %rcx, or %r11.
  16              	 * **************************************************************************
  17              	 */
  18              	
  19              	.globl print_stringz
  20              	.type print_stringz, @function
  21              	.extern strlen
  22              	
  23              	.section .text
  24              	print_stringz:
  25 0000 55       	    pushq   %rbp
  26 0001 4889E5   	    movq    %rsp, %rbp
  27              	    
  28              	    # Save all registers clobbered by strlen or syscall
  29              	    # Standard syscalls clobber %rcx and %r11
  30 0004 50       	    pushq   %rax
  31 0005 51       	    pushq   %rcx
  32 0006 52       	    pushq   %rdx
  33 0007 56       	    pushq   %rsi
  34 0008 57       	    pushq   %rdi
  35 0009 4153     	    pushq   %r11
  36              	
  37              	    # 1. Prepare for strlen
  38 000b 4889F7   	    movq    %rsi, %rdi      # Move string pointer to rdi for strlen
  39 000e E8000000 	    call    strlen          # RAX = length of string
  39      00
  40              	    
  41              	    # 2. Syscall Setup (sys_write)
  42 0013 4889C2   	    movq    %rax, %rdx      # Arg 3: Count (from strlen)
  43              	    # Arg 2: Buffer pointer remains in %rsi from the caller
  44              	    # Arg 1: Retrieve original FD from stack (8 bytes above %r11)
  45 0016 488B7C24 	    movq    8(%rsp), %rdi   
  45      08
  46 001b 48C7C001 	    movq    $1, %rax        # syscall 1 is sys_write
  46      000000
  47 0022 0F05     	    syscall
  48              	
  49              	
  50              	
  51              	    # 3. Restore Everything (Exact reverse order of pushes)
  52 0024 415B     	    popq    %r11
  53 0026 5F       	    popq    %rdi
  54 0027 5E       	    popq    %rsi
GAS LISTING utils/io/print_stringz.s 			page 2


  55 0028 5A       	    popq    %rdx
  56 0029 59       	    popq    %rcx
  57 002a 58       	    popq    %rax
  58              	    
  59 002b 5D       	    popq    %rbp
  60 002c C3       	    ret
  61              	
  62              	.size print_stringz, .-print_stringz
  63              	.section .note.GNU-stack,"",@progbits
