   1              	/*
   2              	 ***************************************************************************
   3              	 * Name          : print_uint8array.s
   4              	 * Description   : Prints an array of 8-bit unsigned integers.
   5              	 * Aligns single digits for clean columns and supports items-per-line.
   6              	 *
   7              	 * ABI           : System V AMD64 (Linux)
   8              	 * Input         : %rdi = Buffer pointer (uint8_t*)
   9              	 * %rsi = Number of elements
  10              	 * %rdx = Items per line (0 for infinite)
  11              	 * Output        : Prints to stdout
  12              	 * **************************************************************************
  13              	 */
