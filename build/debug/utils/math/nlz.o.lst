GAS LISTING utils/math/nlz.s 			page 1


   1              	/*
   2              	 **************************************************************************
   3              	 * Name        : nlz.s
   4              	 * Description : Count leading zeros (64-bit). 
   5              	 * Uses the Branch-Free "Bit-Fill" method for performance.
   6              	 *
   7              	 * ABI         : System V AMD64 (Linux)
   8              	 * Input       : %rdi = 64-bit value to analyze
   9              	 * Output      : %rax = count of leading zeros (0-64)
  10              	 * **************************************************************************
  11              	 */
  12              	
  13              	.section .text
  14              	   
  15              	.globl nlz
  16              	.type nlz, @function
  17              	nlz:
  18              	    # We treat this as a "leaf function" (no calls to other functions).
  19              	    # Therefore, we skip the %rbp prologue to maximize execution speed.
  20              	
  21 0000 4889F8   	    movq    %rdi, %rax
  22 0003 4885C0   	    testq   %rax, %rax
  23 0006 7508     	    jnz     .Lstart_nlz
  24 0008 48C7C040 	    movq    $64, %rax
  24      000000
  25 000f C3       	    ret
  26              	
  27              	.Lstart_nlz:
  28              	    # Bit-Fill: Propagate the highest '1' bit to the right
  29 0010 4889C2   	    movq    %rax, %rdx
  30 0013 48D1EA   	    shrq    $1, %rdx
  31 0016 4809D0   	    orq     %rdx, %rax
  32 0019 4889C2   	    movq    %rax, %rdx
  33 001c 48C1EA02 	    shrq    $2, %rdx
  34 0020 4809D0   	    orq     %rdx, %rax
  35 0023 4889C2   	    movq    %rax, %rdx
  36 0026 48C1EA04 	    shrq    $4, %rdx
  37 002a 4809D0   	    orq     %rdx, %rax
  38 002d 4889C2   	    movq    %rax, %rdx
  39 0030 48C1EA08 	    shrq    $8, %rdx
  40 0034 4809D0   	    orq     %rdx, %rax
  41 0037 4889C2   	    movq    %rax, %rdx
  42 003a 48C1EA10 	    shrq    $16, %rdx
  43 003e 4809D0   	    orq     %rdx, %rax
  44 0041 4889C2   	    movq    %rax, %rdx
  45 0044 48C1EA20 	    shrq    $32, %rdx
  46 0048 4809D0   	    orq     %rdx, %rax
  47              	
  48              	    # RAX is now a contiguous block of 1s (e.g., 00001111)
  49 004b F3480FB8 	    popcntq %rax, %rax        # Count set bits (Significant Width)
  49      C0
  50 0050 48C7C240 	    movq    $64, %rdx
  50      000000
  51 0057 4829C2   	    subq    %rax, %rdx        # 64 - Width = Leading Zeros
  52 005a 4889D0   	    movq    %rdx, %rax
  53 005d C3       	    ret
  54              	
