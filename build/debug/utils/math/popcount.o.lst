GAS LISTING utils/math/popcount.s 			page 1


   1              	/* **************************************************************************
   2              	 * Name         : popcount.s
   3              	 * Assemble     : as --64 popcount.s -o popcount.o
   4              	 * Description  : Counts either set bits (1s) or clear bits (0s) in a register.
   5              	 *
   6              	 * Input        : %rdi = value to analyze
   7              	 * %rsi = target bit type (0 or 1)
   8              	 * Output       : %rax = total count
   9              	 *
  10              	 * Strategy:
  11              	 * This function avoids conditional jumps by using the 'test' and 'setz' 
  12              	 * instructions to create a bit-mask. If the user requests a count of 0s, 
  13              	 * the function XORs the value with -1 (NOT logic) before passing it to the 
  14              	 * hardware 'popcnt' instruction.
  15              	 * ************************************************************************** */
  16              	
  17              	.section .text
  18              	.globl popcount
  19              	.type popcount, @function
  20              	
  21              	popcount:
  22 0000 4889F8   	    movq    %rdi, %rax
  23              	    
  24              	    # 1. Handle the 0-count request without branching.
  25              	    # Logic: If %rsi is 0, we flip all bits in %rax to count zeros as ones.
  26              	    
  27 0003 4885F6   	    testq   %rsi, %rsi          # Is the requested bit 1?
  28 0006 0F94C2   	    setz    %dl                 # %dl = 1 if user requested 0, else 0
  29 0009 480FB6D2 	    movzbq  %dl, %rdx           # Zero extend to 64-bit
  30 000d 48F7DA   	    negq    %rdx                # if 1 -> 0xFF...FF (all 1s), if 0 -> 0
  31              	    
  32 0010 4831D0   	    xorq    %rdx, %rax          # Bitwise NOT if rdx is all 1s, else no change
  33              	
  34              	    # 2. Hardware Population Count
  35              	    # This instruction calculates the number of set bits (Hamming Weight).
  36 0013 F3480FB8 	    popcntq %rax, %rax        
  36      C0
  37              	    
  38 0018 C3       	    ret
  39              	
  40              	.size popcount, .-popcount
  41              	.section .note.GNU-stack,"",@progbits
