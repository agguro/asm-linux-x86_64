GAS LISTING tui/basics/waitforkeypress/waitforkeypress.s 			page 1


   1              	/*
   2              	 **************************************************************************
   3              	 * Name          : waitanykeypress.s
   4              	 * Description   : Displays "Press any key to exit..." and exits as soon
   5              	 * as the first character is received in raw mode.
   6              	 *
   7              	 * Build Sequence:
   8              	 * 1. Assemble Project:
   9              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  10              	 * -al=waitanykeypress.lst waitanykeypress.s \
  11              	 * -o waitanykeypress.o
  12              	 *
  13              	 * 2. Link Executable (PIE enabled):
  14              	 * /usr/bin/ld -m elf_x86_64 -pie -z noexecstack \
  15              	 * --dynamic-linker /lib64/ld-linux-x86-64.so.2 -o waitanykeypress \
  16              	 * waitanykeypress.o
  17              	 *
  18              	 * Strategy:
  19              	 * 1. Print the prompt to stdout.
  20              	 * 2. Use ioctl (TCGETS/TCSETS) to disable ICANON and ECHO.
  21              	 * 3. Call read. In non-canonical mode, this returns on the first key.
  22              	 * 4. Restore original terminal settings and exit.
  23              	 * **************************************************************************
  24              	 */
  25              	
  32              	.list
  33              	
  34              	.section .bss
  35              	    .align 16
  36 0000 00000000 	    .Ltermios: .skip 60
  36      00000000 
  36      00000000 
  36      00000000 
  36      00000000 
  37 003c 00000000 	    .Lbuffer:  .skip 8
  37      00000000 
  38              	
  39              	.section .rodata
  40 0000 50726573 	    .Lmessage: .ascii "Press any key to exit..."
  40      7320616E 
  40      79206B65 
  40      7920746F 
  40      20657869 
  41              	    .equ .Lmessage_len, . - .Lmessage
  42              	
  43              	.section .text
  44              	    .globl _start
  45              	
  46              	_start:
  47              	    # 1. Write prompt to STDOUT
  48:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $write, %eax
  49:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $stdout, %edi
  50:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Lmessage(%rip), %rsi
  51:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $.Lmessage_len, %edx
  52:tui/basics/waitforkeypress/waitforkeypress.s ****     syscall
  53              	
  54              	    # 2. Configure Terminal (Turn off Canonical and Echo)
GAS LISTING tui/basics/waitforkeypress/waitforkeypress.s 			page 2


  55:tui/basics/waitforkeypress/waitforkeypress.s ****     call    termios_canonical_off
  56:tui/basics/waitforkeypress/waitforkeypress.s ****     call    termios_echo_off
  57              	
  58              	    # 3. Read (Returns immediately on any keypress in non-canonical mode)
  59:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $read, %eax
  60:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $stdin, %edi
  61:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Lbuffer(%rip), %rsi
  62:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $1, %edx                # Read 1 byte
  63:tui/basics/waitforkeypress/waitforkeypress.s ****     syscall
  64              	    
  65              	    # 4. Cleanup: Print a newline and restore terminal settings
  66:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Lbuffer(%rip), %rsi
  67:tui/basics/waitforkeypress/waitforkeypress.s ****     movb    $10, (%rsi)             # Put a newline char in the buffer
  68:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $write, %eax
  69:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $stdout, %edi
  70:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $1, %edx
  71:tui/basics/waitforkeypress/waitforkeypress.s ****     syscall
  72              	
  73:tui/basics/waitforkeypress/waitforkeypress.s ****     call    termios_canonical_on
  74:tui/basics/waitforkeypress/waitforkeypress.s ****     call    termios_echo_on
  75              	
  76:tui/basics/waitforkeypress/waitforkeypress.s ****     movl    $exit, %eax
  77:tui/basics/waitforkeypress/waitforkeypress.s ****     xorl    %edi, %edi
  78:tui/basics/waitforkeypress/waitforkeypress.s ****     syscall
  79              	
  80              	# --- Termios Helper Functions ---
  81              	
  82              	termios_canonical_on:
  83:tui/basics/waitforkeypress/waitforkeypress.s ****     movl $ICANON, %eax
  84:tui/basics/waitforkeypress/waitforkeypress.s ****     jmp .Lset_flag
  85              	termios_canonical_off: 
  86:tui/basics/waitforkeypress/waitforkeypress.s ****     movl $ICANON, %eax
  87:tui/basics/waitforkeypress/waitforkeypress.s ****     jmp .Lclear_flag
  88              	termios_echo_on:
  89:tui/basics/waitforkeypress/waitforkeypress.s ****     movl $ECHO,   %eax
  90:tui/basics/waitforkeypress/waitforkeypress.s ****     jmp .Lset_flag
  91              	termios_echo_off:
  92:tui/basics/waitforkeypress/waitforkeypress.s ****     movl $ECHO,   %eax
  93              	
  94              	.Lclear_flag:
  95:tui/basics/waitforkeypress/waitforkeypress.s ****     pushq   %rax
  96:tui/basics/waitforkeypress/waitforkeypress.s ****     call    .Lread_state
  97:tui/basics/waitforkeypress/waitforkeypress.s ****     popq    %rax
  98:tui/basics/waitforkeypress/waitforkeypress.s ****     notq    %rax
  99:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Ltermios(%rip), %rdx
 100:tui/basics/waitforkeypress/waitforkeypress.s ****     andq    %rax, 12(%rdx)          # Clear the bit in c_lflag
 101:tui/basics/waitforkeypress/waitforkeypress.s ****     jmp     .Lwrite_state
 102              	
 103              	.Lset_flag:
 104:tui/basics/waitforkeypress/waitforkeypress.s ****     pushq   %rax
 105:tui/basics/waitforkeypress/waitforkeypress.s ****     call    .Lread_state
 106:tui/basics/waitforkeypress/waitforkeypress.s ****     popq    %rax
 107:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Ltermios(%rip), %rdx
 108:tui/basics/waitforkeypress/waitforkeypress.s ****     orq     %rax, 12(%rdx)          # Set the bit in c_lflag
 109              	
 110              	.Lwrite_state:
 111:tui/basics/waitforkeypress/waitforkeypress.s ****     movq    $TCSETS, %rsi
GAS LISTING tui/basics/waitforkeypress/waitforkeypress.s 			page 3


 112:tui/basics/waitforkeypress/waitforkeypress.s ****     jmp     .Lioctl_sys
 113              	.Lread_state:
 114:tui/basics/waitforkeypress/waitforkeypress.s ****     movq    $TCGETS, %rsi
 115              	.Lioctl_sys:
 116:tui/basics/waitforkeypress/waitforkeypress.s ****     leaq    .Ltermios(%rip), %rdx
 117:tui/basics/waitforkeypress/waitforkeypress.s ****     movq    $stdin, %rdi
 118:tui/basics/waitforkeypress/waitforkeypress.s ****     movq    $ioctl, %rax
 119:tui/basics/waitforkeypress/waitforkeypress.s ****     syscall
 120:tui/basics/waitforkeypress/waitforkeypress.s ****     ret
