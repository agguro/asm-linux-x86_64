GAS LISTING tui/basics/printenv/printenv.s 			page 1


   1              	/*
   2              	 **************************************************************************
   3              	 * Name          : printenv.s
   4              	 * Description   : Linux environment variable printer. Supports -0/--null,
   5              	 * --help, and --version.
   6              	 *
   7              	 * Build Sequence:
   8              	 * 1. Assemble Project:
   9              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  10              	 * -al=printenv.lst printenv.s -o printenv.o
  11              	 *
  12              	 * 2. Link Executable (PIE enabled):
  13              	 * /usr/bin/ld -m elf_x86_64 -pie -z noexecstack \
  14              	 * --dynamic-linker /lib64/ld-linux-x86-64.so.2 -o printenv printenv.o
  15              	 *
  16              	 * Strategy:
  17              	 * 1. Parse command-line arguments (argv) for options starting with '-'.
  18              	 * 2. If --null is requested, change the end-of-line character to 0.
  19              	 * 3. Access envp by skipping argc and all argv pointers on the stack.
  20              	 * 4. Iterate through envp strings and print those that match the request.
  21              	 * 5. If no variable is requested, print the entire envp list.
  22              	 * **************************************************************************
  23              	 */
  24              	
  27              	.list
  28              	
  29              	.extern strlen
  30              	.extern print_stringz
  31              	
  32              	.section .bss
  33              	    .align 16
  34 0000 00       	    .Lbuffer:       .skip 1
  35              	
  36              	.section .data
  37              	    # Added a null terminator so print_stringz works correctly
  38 0000 0A00     	    .Lendofline:    .byte 10, 0        
  39              	
  40              	.section .rodata
  41              	    .Lusage:
  42 0000 55736167 	        .ascii "Usage: ./printenv [OPTION]... [VARIABLE]...\n"
  42      653A202E 
  42      2F707269 
  42      6E74656E 
  42      76205B4F 
  43 002c 5072696E 	        .ascii "Print the values of the specified environment VARIABLE(s).\n\n"
  43      74207468 
  43      65207661 
  43      6C756573 
  43      206F6620 
  44 0068 2D302C20 	        .ascii "-0, --null      end each output line with 0 byte rather than newline\n"
  44      2D2D6E75 
  44      6C6C2020 
  44      20202020 
  44      656E6420 
  45 00ad 20202020 	        .ascii "    --help      display this help and exit\n"
  45      2D2D6865 
  45      6C702020 
