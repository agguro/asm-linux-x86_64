  58              	_start:
  59:tui/basics/printenv/printenv.s ****     popq    %rbx                    # argc
  60:tui/basics/printenv/printenv.s ****     popq    %rax                    # argv[0]
  61:tui/basics/printenv/printenv.s ****     cmpq    $1, %rbx
  62:tui/basics/printenv/printenv.s ****     je      .LGetAllVariables            
  63              	
  64              	    # Get first argument (argv[1])
  65:tui/basics/printenv/printenv.s ****     popq    %rsi                    
  66:tui/basics/printenv/printenv.s ****     movq    %rsi, %r15              # Save pointer for error msg
  67              	    
  68:tui/basics/printenv/printenv.s ****     cld
  69:tui/basics/printenv/printenv.s ****     lodsb                           # Load first char
  70:tui/basics/printenv/printenv.s ****     cmpb    $'-', %al               # Is it an option?
  71:tui/basics/printenv/printenv.s ****     je      .LHandleOptions
  72              	    
  73              	    # Not an option: search for specific variable
  74:tui/basics/printenv/printenv.s ****     decq    %rsi                    
  75:tui/basics/printenv/printenv.s ****     pushq   %rsi                    # Push target name to stack
  76:tui/basics/printenv/printenv.s ****     jmp     .LGetVariable
  77              	
  78              	.LHandleOptions:
  79:tui/basics/printenv/printenv.s ****     lodsb
  80:tui/basics/printenv/printenv.s ****     cmpb    $'0', %al
GAS LISTING tui/basics/printenv/printenv.s 			page 3


  81:tui/basics/printenv/printenv.s ****     je      .LIsNull
  82:tui/basics/printenv/printenv.s ****     cmpb    $'-', %al
  83:tui/basics/printenv/printenv.s ****     jne     .LInvalidOption             
  84              	    
  85              	    # Simple Long Option Parsing (help/null/version)
  86:tui/basics/printenv/printenv.s ****     lodsl                           # Load 4 bytes into EAX
  87:tui/basics/printenv/printenv.s ****     cmpl    $0x706c6568, %eax       # "help"
  88:tui/basics/printenv/printenv.s ****     je      .LIsHelp
  89:tui/basics/printenv/printenv.s ****     cmpl    $0x6c6c756e, %eax       # "null"
  90:tui/basics/printenv/printenv.s ****     je      .LIsNull
  91              	    
  92              	    # Check for "version"
  93:tui/basics/printenv/printenv.s ****     decq    %rsi
  94:tui/basics/printenv/printenv.s ****     movq    (%rsi), %rax
  95:tui/basics/printenv/printenv.s ****     movabsq $0x6e6f6973726576, %r8  # "version"
  96:tui/basics/printenv/printenv.s ****     cmpq    %r8, %rax
  97:tui/basics/printenv/printenv.s ****     je      .LIsVersion
  98:tui/basics/printenv/printenv.s ****     jmp     .Lexit
  99              	
 100              	.LIsNull:
 101:tui/basics/printenv/printenv.s ****     leaq    .Lendofline(%rip), %rax
 102:tui/basics/printenv/printenv.s ****     movb    $0, (%rax)              # Change newline to null
 103:tui/basics/printenv/printenv.s ****     cmpq    $2, %rbx                # Was it just './printenv -0'?
 104:tui/basics/printenv/printenv.s ****     jne     .LGetVariable
 105:tui/basics/printenv/printenv.s ****     jmp     .LGetAllVariables
 106              	
 107              	.LIsHelp:
 108:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi
 109:tui/basics/printenv/printenv.s ****     leaq    .Lusage(%rip), %rsi
 110:tui/basics/printenv/printenv.s ****     call    print_stringz
 111:tui/basics/printenv/printenv.s ****     jmp     .Lexit
 112              	
 113              	.LIsVersion:
 114:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi
 115:tui/basics/printenv/printenv.s ****     leaq    .Lversion(%rip), %rsi
 116:tui/basics/printenv/printenv.s ****     call    print_stringz
 117:tui/basics/printenv/printenv.s ****     jmp     .Lexit
 118              	
 119              	.LInvalidOption:
 120:tui/basics/printenv/printenv.s ****     movl    $stderr, %edi
 121:tui/basics/printenv/printenv.s ****     leaq    .Linvalid(%rip), %rsi
 122:tui/basics/printenv/printenv.s ****     call    print_stringz
 123              	    
 124              	    # Print the specific character that failed
 125:tui/basics/printenv/printenv.s ****     movl    $stderr, %edi
 126:tui/basics/printenv/printenv.s ****     movq    %r15, %rsi
 127              	    # We only want to print the char, so we temporarily null-terminate or use write
 128:tui/basics/printenv/printenv.s ****     movl    $write, %eax
 129:tui/basics/printenv/printenv.s ****     movl    $2, %edx                # Print the "-" and the char
 130:tui/basics/printenv/printenv.s ****     syscall
 131              	
 132:tui/basics/printenv/printenv.s ****     movl    $stderr, %edi
 133:tui/basics/printenv/printenv.s ****     leaq    .Loption_msg(%rip), %rsi
 134:tui/basics/printenv/printenv.s ****     call    print_stringz
 135:tui/basics/printenv/printenv.s ****     jmp     .Lexit
 136              	
 137              	.LGetAllVariables:
GAS LISTING tui/basics/printenv/printenv.s 			page 4


 138:tui/basics/printenv/printenv.s ****     popq    %rsi                    # Skip NULL terminator of argv
 139              	.LNextVariable:    
 140:tui/basics/printenv/printenv.s ****     popq    %rsi                    # Get envp[i] pointer
 141:tui/basics/printenv/printenv.s ****     testq   %rsi, %rsi              # End of envp?
 142:tui/basics/printenv/printenv.s ****     jz      .Lexit
 143              	    
 144:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi
 145:tui/basics/printenv/printenv.s ****     call    print_stringz           # Print NAME=VALUE
 146              	    
 147:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi
 148:tui/basics/printenv/printenv.s ****     leaq    .Lendofline(%rip), %rsi
 149:tui/basics/printenv/printenv.s ****     call    print_stringz           # Print EOL
 150:tui/basics/printenv/printenv.s ****     jmp     .LNextVariable
 151              	
 152              	.LGetVariable:
 153:tui/basics/printenv/printenv.s ****     popq    %rdi                    # Target variable name
 154:tui/basics/printenv/printenv.s ****     pushq   %rdi
 155:tui/basics/printenv/printenv.s ****     call    strlen                  # Use library strlen!
 156:tui/basics/printenv/printenv.s ****     movq    %rax, %rcx              # RCX = length of search name
 157              	    
 158:tui/basics/printenv/printenv.s ****     popq    %rdi                    # Restore target name
 159:tui/basics/printenv/printenv.s ****     popq    %rsi                    # Skip NULL argv spacer
 160              	.LgetNV:
 161:tui/basics/printenv/printenv.s ****     popq    %rsi                    # Get next envp string
 162:tui/basics/printenv/printenv.s ****     testq   %rsi, %rsi
 163:tui/basics/printenv/printenv.s ****     jz      .Lexit                  # Not found
 164              	    
 165:tui/basics/printenv/printenv.s ****     pushq   %rdi
 166:tui/basics/printenv/printenv.s ****     pushq   %rcx
 167:tui/basics/printenv/printenv.s ****     pushq   %rsi                    
 168              	    
 169:tui/basics/printenv/printenv.s ****     repe    cmpsb                   # Compare strings
 170:tui/basics/printenv/printenv.s ****     jne     .LnoMatch
 171              	    
 172:tui/basics/printenv/printenv.s ****     cmpb    $'=', (%rsi)            # Is it followed by '='?
 173:tui/basics/printenv/printenv.s ****     je      .LFoundMatch
 174              	
 175              	.LnoMatch:
 176:tui/basics/printenv/printenv.s ****     popq    %rsi
 177:tui/basics/printenv/printenv.s ****     popq    %rcx
 178:tui/basics/printenv/printenv.s ****     popq    %rdi
 179:tui/basics/printenv/printenv.s ****     jmp     .LgetNV
 180              	
 181              	.LFoundMatch:
 182:tui/basics/printenv/printenv.s ****     incq    %rsi                    # Skip '='
 183:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi           # %rsi points to the value
 184:tui/basics/printenv/printenv.s ****     call    print_stringz           
 185              	    
 186:tui/basics/printenv/printenv.s ****     movl    $stdout, %edi
 187:tui/basics/printenv/printenv.s ****     leaq    .Lendofline(%rip), %rsi
 188:tui/basics/printenv/printenv.s ****     call    print_stringz
 189              	
 190              	.Lexit:
 191:tui/basics/printenv/printenv.s ****     movl    $exit, %eax
 192:tui/basics/printenv/printenv.s ****     xorl    %edi, %edi
 193:tui/basics/printenv/printenv.s ****     syscall
