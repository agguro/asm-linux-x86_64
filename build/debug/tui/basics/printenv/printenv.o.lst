  50 0128 4E41534D 	        .ascii "NASM version written by agguro\n\0"
  50      20766572 
  50      73696F6E 
  50      20777269 
  50      7474656E 
  51              	    
  52 0148 7072696E 	    .Linvalid:      .ascii "printenv: invalid option '\0"
  52      74656E76 
  52      3A20696E 
  52      76616C69 
  52      64206F70 
  53 0163 270A5472 	    .Loption_msg:   .ascii "'\nTry `printenv --help` for more information.\n\0"
