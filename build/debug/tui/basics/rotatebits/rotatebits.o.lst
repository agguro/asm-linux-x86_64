   1              	/*
   2              	 **************************************************************************
   3              	 * Name         : rotatebits.s
   4              	 *
   5              	 * Build Sequence:
   6              	 * 1. Assemble Project Main:
   7              	 * as --64 -g --noexecstack -I ../../../include \
   8              	 * -al=rotatebits.lst rotatebits.s -o rotatebits.o
   9              	 *
  10              	 * 2. Assemble Library Dependencies:
  11              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  12              	 * -al=print_stringz.lst ../../../lib/print_stringz.s -o print_stringz.o
  13              	 *
  14              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  15              	 * -al=u64tobin.lst ../../../lib/u64tobin.s -o u64tobin.o
  16              	 *
  17              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  18              	 * -al=signed_rotate.lst ../../../lib/signed_rotate.s -o signed_rotate.o
  19              	 *
  20              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  21              	 * -al=strlen.lst ../../../lib/strlen.s -o strlen.o
  22              	 *
  23              	 * 3. Link Executable (PIE enabled):
  24              	 * /usr/bin/ld -m elf_x86_64 -pie -z noexecstack \
  25              	 * --dynamic-linker /lib64/ld-linux-x86-64.so.2 -o rotatebits \
  26              	 * rotatebits.o print_stringz.o u64tobin.o signed_rotate.o strlen.o
  27              	 *
  28              	 *
  29              	 * Signed Bit-Window Rotation (x86-64 Assembly)
  30              	 * --------------------------------------------
  31              	 * This library provides a specialized circular rotation for bitstrings of 
  32              	 * arbitrary lengths (2 to 64 bits). Unlike standard ROL/ROR, this treats a
  33              	 * specific "window" as the universe.
  34              	 *
  35              	 * The Golden Rule: The most significant bit (the "Sign Bit") acts as a 
  36              	 * fixed wall. It never moves. Lower bits rotate circularly.
  37              	 *
  38              	 * Key Features:
  39              	 * - Custom Universe: ignores bits 7–63 if Bitlength is 7.
  40              	 * - Shortest Path: "Left 14" on 16-bits becomes "Right 1" internally.
  41              	 * - Implicit ABI: srol/sror use (Value, Bitlength, Count).
  42              	 * - No "Ghost Bits": Advanced masking prevents data leakage.
  43              	 *
  44              	 * How it Works:
  45              	 * - Normalization: Uses divq to find Count % Window.
  46              	 * - Isolation: Splits register into "The Wall" and "The Body".
  47              	 * - Manual Bridge: Catches bits "falling off" and wraps them manually.
  48              	 * - Re-assembly: ORs the fixed "Wall" back onto the "Body".
  49              	 *
  50              	 * Example Usage (6-bit rotation, Left 3):
  51              	 * movq $0b100100, %rdi  # Value
  52              	 * movq $6, %rsi         # Bitlength
  53              	 * movq $3, %rdx         # Count
  54              	 * call srol             # Result in %rax = 0b100001
  55              	 *
  56              	 * Technical Constraints:
  57              	 * - Min: 2 bits | Max: 64 bits
GAS LISTING tui/basics/rotatebits/rotatebits.s 			page 2


  58              	 * - Registers: r10-r13 internal (callee-saved restored).
  59              	 * **************************************************************************
  60              	 */
  61              	
  62              	.equ VALUE, 0b1111111101100100   # Input data
  63              	.equ BITLEN, 6                   # Universe size (6 bits)
  64              	
  67              	.list
  68              	
  69              	.section .rodata
  70 0000 4F726967 	    msg_orig:   .asciz "Original:       "
  70      696E616C 
  70      3A202020 
  70      20202020 
  70      00
  71 0011 0A526F74 	    msg_rot_l:  .asciz "\nRotate 3 Left:  "
  71      61746520 
  71      33204C65 
  71      66743A20 
  71      2000
  72 0023 0A526F74 	    msg_rot_r:  .asciz "\nRotate 2 Right: "
  72      61746520 
  72      32205269 
  72      6768743A 
  72      2000
  73 0035 0A00     	    msg_nl:     .asciz "\n"
  74              	
  75              	.section .bss
  76              	    .align 16
  77 0000 00000000 	    reg64: .skip 65
  77      00000000 
  77      00000000 
  77      00000000 
  77      00000000 
  78              	
  79              	.section .text
  80              	.globl _start
  81              	
  82              	.extern print_stringz
  83              	.extern u64tobin
  84              	.extern srol           # part of signed_rotate.s
  85              	.extern sror           # part of signed_rotate.s
  86              	
  87              	_start:
  88              	    # --- 1. ORIGINAL ---
  89:tui/basics/rotatebits/rotatebits.s ****     movq    $VALUE, %r12
  90:tui/basics/rotatebits/rotatebits.s ****     movq    $BITLEN, %r13
  91              	
  92:tui/basics/rotatebits/rotatebits.s ****     movq    $stdout, %rdi
  93:tui/basics/rotatebits/rotatebits.s ****     leaq    msg_orig(%rip), %rsi
  94:tui/basics/rotatebits/rotatebits.s ****     call    print_stringz
  95              	
  96:tui/basics/rotatebits/rotatebits.s ****     movq    %r12, %rdi
  97:tui/basics/rotatebits/rotatebits.s ****     leaq    reg64(%rip), %rsi
  98:tui/basics/rotatebits/rotatebits.s ****     movq    %r13, %rdx          # Display in BITLEN width
  99:tui/basics/rotatebits/rotatebits.s ****     call    u64tobin
 100              	    
