GAS LISTING tui/basics/cpuid/cpuid.s 			page 1


   1              	/* 
   2              	 **************************************************************************
   3              	 * Name         : cpuid.s
   4              	 * Description  : Checks for CPUID support and displays the Vendor ID string.
   5              	 *
   6              	 *
   7              	 * Build Sequence:
   8              	 * 1. Assemble Project Main:
   9              	 * /usr/bin/as --64 -g --noexecstack -I ../../../include \
  10              	 * -al=cpuid.lst cpuid.s -o cpuid.o
  11              	 *
  12              	 * 2. Link Executable (PIE enabled):
  13              	 * /usr/bin/ld -m elf_x86_64 -pie -z noexecstack \
  14              	 * --dynamic-linker /lib64/ld-linux-x86-64.so.2 -o cpuid \
  15              	 * cpuid.o
  16              	 *
  17              	 *
  18              	 * Overview:
  19              	 * The CPUID instruction is the gateway to discovering processor features. 
  20              	 * However, before using it, a program must verify it is supported by 
  21              	 * attempting to flip Bit 21 (the ID bit) in the RFLAGS register.
  22              	 *
  23              	 * Logic Flow:
  24              	 * 1. Check Support: Attempt to flip the ID bit in RFLAGS. If the bit 
  25              	 * remains changed after being pushed and popped, CPUID is supported.
  26              	 * 2. CPUID EAX=0: Calling CPUID with EAX set to 0 returns a 12-character 
  27              	 * Vendor ID string spread across three registers: EBX, EDX, and ECX.
  28              	 * 3. Sequence: For "GenuinIintel", the order is EBX (Genu), EDX (ineI), 
  29              	 * and ECX (ntel).
  30              	 * **************************************************************************
  31              	 */
  32              	
  35              	.list
  36              	
  37              	.section .rodata
  38 0000 54686520 	    msg_prefix:     .ascii "The processor Vendor ID is '"
  38      70726F63 
  38      6573736F 
  38      72205665 
  38      6E646F72 
  39              	    msg_prefix_len = . - msg_prefix
  40              	
  41 001c 270A     	    msg_suffix:     .ascii "'\n"
  42              	    msg_suffix_len = . - msg_suffix
  43              	
  44 001e 43505549 	    msg_error:      .ascii "CPUID is not supported\n"
  44      44206973 
  44      206E6F74 
  44      20737570 
  44      706F7274 
  45              	    msg_error_len = . - msg_error
  46              	
  47              	.section .bss
  48              	    .lcomm vendor_id, 12            # Reserve 12 bytes for Vendor ID string
  49              	
  50              	.section .text
  51              	    .globl _start
GAS LISTING tui/basics/cpuid/cpuid.s 			page 2


  52              	
  53              	_start:
  54              	    # --- Step 1: Check for CPUID Support ---
  55              	    # Bit 21 (ID bit) in FLAGS indicates support for the CPUID instruction.
  56:tui/basics/cpuid/cpuid.s ****     pushfq
  57:tui/basics/cpuid/cpuid.s ****     popq    %rax
  58:tui/basics/cpuid/cpuid.s ****     movq    %rax, %rcx              # Save original RFLAGS
  59:tui/basics/cpuid/cpuid.s ****     xorq    $0x200000, %rax         # Flip bit 21
  60:tui/basics/cpuid/cpuid.s ****     pushq   %rax
  61:tui/basics/cpuid/cpuid.s ****     popfq                           # Attempt to set new RFLAGS
  62:tui/basics/cpuid/cpuid.s ****     pushfq
  63:tui/basics/cpuid/cpuid.s ****     popq    %rax                    # Read RFLAGS back
  64:tui/basics/cpuid/cpuid.s ****     xorq    %rcx, %rax              # Compare with the original
  65:tui/basics/cpuid/cpuid.s ****     testq   $0x200000, %rax 
  66:tui/basics/cpuid/cpuid.s ****     jz      .no_support             # Jump if bit 21 could not be flipped
  67              	
  68              	    # --- Step 2: Get CPUID Data ---
  69:tui/basics/cpuid/cpuid.s ****     movl    $0, %eax                # Function 0: Get Vendor ID
  70:tui/basics/cpuid/cpuid.s ****     cpuid                           # Returns string in EBX, EDX, ECX
  71              	
  72              	
  73              	
  74              	    # Get address of BSS buffer via RIP-relative addressing
  75:tui/basics/cpuid/cpuid.s ****     leaq    vendor_id(%rip), %rdi
  76              	    
  77              	    # Store the 12-byte Vendor ID (Order: EBX, EDX, ECX)
  78:tui/basics/cpuid/cpuid.s ****     movl    %ebx, (%rdi)            # First 4 bytes
  79:tui/basics/cpuid/cpuid.s ****     movl    %edx, 4(%rdi)           # Next 4 bytes
  80:tui/basics/cpuid/cpuid.s ****     movl    %ecx, 8(%rdi)           # Final 4 bytes
  81              	
  82              	    # --- Step 3: Print Sequence ---
  83              	    
  84              	    # 1. Print Prefix
  85:tui/basics/cpuid/cpuid.s ****     leaq    msg_prefix(%rip), %rsi
  86:tui/basics/cpuid/cpuid.s ****     movq    $msg_prefix_len, %rdx
  87:tui/basics/cpuid/cpuid.s ****     movq    $stdout, %rdi
  88:tui/basics/cpuid/cpuid.s ****     movq    $write, %rax
  89:tui/basics/cpuid/cpuid.s ****     syscall
  90              	
  91              	    # 2. Print The Vendor ID
  92:tui/basics/cpuid/cpuid.s ****     leaq    vendor_id(%rip), %rsi
  93:tui/basics/cpuid/cpuid.s ****     movq    $12, %rdx
  94:tui/basics/cpuid/cpuid.s ****     movq    $stdout, %rdi
  95:tui/basics/cpuid/cpuid.s ****     movq    $write, %rax
  96:tui/basics/cpuid/cpuid.s ****     syscall
  97              	
  98              	    # 3. Print Suffix
  99:tui/basics/cpuid/cpuid.s ****     leaq    msg_suffix(%rip), %rsi
 100:tui/basics/cpuid/cpuid.s ****     movq    $msg_suffix_len, %rdx
 101:tui/basics/cpuid/cpuid.s ****     movq    $stdout, %rdi
 102:tui/basics/cpuid/cpuid.s ****     movq    $write, %rax
 103:tui/basics/cpuid/cpuid.s ****     syscall
 104              	
 105              	    # Exit success
 106:tui/basics/cpuid/cpuid.s ****     xorq    %rdi, %rdi              # Exit status 0
 107:tui/basics/cpuid/cpuid.s ****     movq    $exit, %rax             # sys_exit
 108:tui/basics/cpuid/cpuid.s ****     syscall
GAS LISTING tui/basics/cpuid/cpuid.s 			page 3


 109              	
 110              	.no_support:
 111              	    # Print Error and Exit with status 1
 112:tui/basics/cpuid/cpuid.s ****     leaq    msg_error(%rip), %rsi
 113:tui/basics/cpuid/cpuid.s ****     movq    $msg_error_len, %rdx
 114:tui/basics/cpuid/cpuid.s ****     movq    $stdout, %rdi
 115:tui/basics/cpuid/cpuid.s ****     movq    $write, %rax
 116:tui/basics/cpuid/cpuid.s ****     syscall
 117              	    
 118:tui/basics/cpuid/cpuid.s ****     movq    $1, %rdi                # Exit status 1
 119:tui/basics/cpuid/cpuid.s ****     movq    $exit, %rax
 120:tui/basics/cpuid/cpuid.s ****     syscall
 121              	
 122              	.size _start, . - _start
 123              	.section .note.GNU-stack,"",@progbits
