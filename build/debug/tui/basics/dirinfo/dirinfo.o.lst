 234              	# --- Helpers ---
 235              	
 236              	.Lprepare_conv_buffer:
 237              	    # Set RSI = start, RDX = 63, and place null at index 63
 238:tui/basics/dirinfo/dirinfo.s ****     leaq    conv_buf(%rip), %rsi
 239:tui/basics/dirinfo/dirinfo.s ****     movq    $63, %rdx
 240:tui/basics/dirinfo/dirinfo.s ****     movb    $0, 63(%rsi)                    # Pre-terminate the buffer
 241:tui/basics/dirinfo/dirinfo.s ****     ret
 242              	
 243              	.Lprint_lib_output:
 244              	    # Library returns pointer in RSI
 245              	    # Since we pre-terminated, it is a valid Z-string
 246:tui/basics/dirinfo/dirinfo.s ****     movq    $stdout, %rdi
 247:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 248:tui/basics/dirinfo/dirinfo.s ****     ret
 249              	
 250              	.Lprint_spacers:
 251:tui/basics/dirinfo/dirinfo.s ****     movq    %rax, %rcx
 252:tui/basics/dirinfo/dirinfo.s **** 1:  pushq   %rcx
 253:tui/basics/dirinfo/dirinfo.s ****     leaq    spacer(%rip), %rsi
 254:tui/basics/dirinfo/dirinfo.s ****     movq    $stdout, %rdi
 255:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 256:tui/basics/dirinfo/dirinfo.s ****     popq    %rcx
 257:tui/basics/dirinfo/dirinfo.s ****     loop    1b
 258:tui/basics/dirinfo/dirinfo.s ****     ret
