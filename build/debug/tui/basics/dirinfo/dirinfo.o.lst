 180              	
 181              	    # --- Column: File Type ---
 182:tui/basics/dirinfo/dirinfo.s ****     leaq    spacer(%rip), %rsi
 183:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 184              	    
 185:tui/basics/dirinfo/dirinfo.s ****     movzbq  18(%r13), %rax                  # d_type numeric index
 186:tui/basics/dirinfo/dirinfo.s ****     andq    $0x0F, %rax                     # Ensure index is within range (0-8)
 187              	    
 188:tui/basics/dirinfo/dirinfo.s ****     leaq    type_table(%rip), %rbx          # Get base address of table (PIE-safe)
 189:tui/basics/dirinfo/dirinfo.s ****     movq    (%rbx, %rax, 8), %rsi           # Load the relative OFFSET from table
 190:tui/basics/dirinfo/dirinfo.s ****     addq    %rbx, %rsi                      # Final Pointer = Table Base + Offset
 191              	    
 192:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz                   # Now RSI points to a valid string
 193              	
 194:tui/basics/dirinfo/dirinfo.s ****     leaq    col(%rip), %rsi
 195:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 196              	
