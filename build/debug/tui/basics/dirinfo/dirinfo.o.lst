 128:tui/basics/dirinfo/dirinfo.s ****     movzwq  16(%rbx), %rcx                  # rcx = d_reclen
 129              	    
 130              	    # Copy record to local buffer
 131:tui/basics/dirinfo/dirinfo.s ****     movq    %rbx, %rsi
 132:tui/basics/dirinfo/dirinfo.s ****     leaq    dirent_buf(%rip), %rdi
 133:tui/basics/dirinfo/dirinfo.s ****     pushq   %rcx                     
 134:tui/basics/dirinfo/dirinfo.s ****     cld
 135:tui/basics/dirinfo/dirinfo.s ****     rep     movsb
 136:tui/basics/dirinfo/dirinfo.s ****     popq    %rcx                     
 137              	
 138:tui/basics/dirinfo/dirinfo.s ****     leaq    dirent_buf(%rip), %r13          # r13 = local entry floor
 139              	    
