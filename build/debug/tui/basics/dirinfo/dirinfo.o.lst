 121:tui/basics/dirinfo/dirinfo.s ****     leaq    line(%rip), %rsi
 122:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 123              	    
 124:tui/basics/dirinfo/dirinfo.s ****     xorq    %r12, %r12                      # r12 = offset tracker
