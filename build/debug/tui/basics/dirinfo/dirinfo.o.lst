 200:tui/basics/dirinfo/dirinfo.s ****     leaq    19(%r13), %rsi                  # d_name
 201:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 202              	    
 203:tui/basics/dirinfo/dirinfo.s ****     leaq    crlf(%rip), %rsi
 204:tui/basics/dirinfo/dirinfo.s ****     call    print_stringz
 205              	    
 206              	    # Advance
