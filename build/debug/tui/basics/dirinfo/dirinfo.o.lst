GAS LISTING tui/basics/dirinfo/dirinfo.s 			page 1


   1              	/* 
   2              	 **************************************************************************
   3              	 * Name         : dirinfo.s
   4              	 * Description  : Displays detailed directory entry information for the 
   5              	 * current working directory.
   6              	 *
   7              	 *
   8              	 * Build Sequence:
   9              	 * 1. Assemble Project Main:
  10              	 * as --64 -g dirinfo.s -o dirinfo.o
  11              	 *
  12              	 * * 2. Assemble Libraries:
  13              	 * as --64 -g strlen.s -o strlen.o
  14              	 * as --64 -g print_stringz.s -o print_stringz.o
  15              	 * as --64 -g u64toa.s -o u64toa.o
  16              	 * as --64 -g u64tohex.s -o u64tohex.o
  17              	 *
  18              	 * 3. Link Executable:
  19              	 * ld -m elf_x86_64 -pie --dynamic-linker /lib64/ld-linux-x86-64.so.2 \
  20              	 * -o dirinfo dirinfo.o strlen.o print_stringz.o u64toa.o u64tohex.o
  21              	 *
  22              	 *
  23              	 * Overview:
  24              	 * This program utilizes the Linux 'getdents64' syscall to read raw directory
  25              	 * structures. It parses the resulting buffer to extract inodes, offsets,
  26              	 * record lengths, and file types, formatting them into a readable table.
  27              	 *
  28              	 * Logic Flow:
  29              	 * 1. Opens the current directory (".") using O_DIRECTORY flag.
  30              	 * 2. Reads directory entries into a 4KB buffer.
  31              	 * 3. Iterates through the buffer using 'd_reclen' to find the next entry.
  32              	 * 4. Translates the 'd_type' byte into a human-readable string using a
  33              	 * PIE-safe lookup table.
  34              	 * 5. Uses external library functions for numeric-to-string conversion.
  35              	 * **************************************************************************
  36              	 */
  37              	
  40              	.list
  41              	
  42              	.equ O_RDONLY, 0
  43              	.equ O_DIRECTORY, 0200000
  44              	
  45              	.section .rodata
  46 0000 2020696E 	    tableheader: .asciz "  inode   |   next entry     | record length |        filetype          | 
  46      6F646520 
  46      20207C20 
  46      20206E65 
  46      78742065 
  47 0057 20202020 	    totallength: .asciz "                  Total length |"
  47      20202020 
  47      20202020 
  47      20202020 
  47      2020546F 
  48 0078 2000     	    spacer:      .asciz " "
  49 007a 7C00     	    col:         .asciz "|"
  50 007c 2D2D2D2D 	    line:        .asciz "--------------------------------------------------------------------------
  50      2D2D2D2D 
GAS LISTING tui/basics/dirinfo/dirinfo.s 			page 2


  50      2D2D2D2D 
  50      2D2D2D2D 
  50      2D2D2D2D 
