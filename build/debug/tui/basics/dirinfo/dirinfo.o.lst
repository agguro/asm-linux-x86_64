 104              	    # 2. Get Directory Entries
 105:tui/basics/dirinfo/dirinfo.s ****     movq    %rax, %rdi               
 106:tui/basics/dirinfo/dirinfo.s ****     leaq    buffer(%rip), %rsi
 107:tui/basics/dirinfo/dirinfo.s ****     movq    $BUFFER_LEN, %rdx
 108:tui/basics/dirinfo/dirinfo.s ****     movq    $getdents64, %rax
 109:tui/basics/dirinfo/dirinfo.s ****     syscall
 110              	    
 111:tui/basics/dirinfo/dirinfo.s ****     cmpq    $0, %rax
 112:tui/basics/dirinfo/dirinfo.s ****     jle     .Lcleanup               
 113:tui/basics/dirinfo/dirinfo.s ****     movq    %rax, nread(%rip)
 114              	    
