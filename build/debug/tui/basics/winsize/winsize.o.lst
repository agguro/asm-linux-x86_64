GAS LISTING tui/basics/winsize/winsize.s 			page 1


   1              	/*
   2              	 **************************************************************************
   3              	 * Name          : winsize.s
   4              	 * Description   : Displays terminal dimensions (Rows, Cols, Pixels).
   5              	 *
   6              	 * Build Sequence:
   7              	 * 1. Assemble: as --64 -g -I ../../../include winsize.s -o winsize.o
   8              	 *              as --64 -g -I ../../../lib strlen.s strlen.o
   9              	 *              as --64 -g -I ../../../lib print_stringz.s print_stringz.o
  10              	 *              as --64 -g -I ../../../lib u64toa.s u64toa.o
  11              	 *
  12              	 * 2. Link:     ld -m elf_x86_64 -pie -o winsize winsize.o \
  13              	 *              strlen.o print_stringz.o u64toa.o
  14              	 *
  15              	 * Strategy:
  16              	 * 1. Use 'ioctl' with TIOCGWINSZ to populate the winsize structure.
  17              	 * 2. Iterate through the structure's 4 words (rows, cols, xpixel, ypixel).
  18              	 * 3. Use the high-performance 'u64toa' library to convert numbers to strings.
  19              	 * 4. Print results using the ABI-transparent 'print_stringz' library.
  20              	 * **************************************************************************
  21              	 */
  22              	 
  25              	.list
  26              	
  27              	# --- Local Definitions (Replacing termios.inc) ---
  28              	.equ TIOCGWINSZ, 0x5413             # Kernel constant to "Get Window Size"
  29              	.equ WINSIZE_SIZE, 8                # Structure is 4 x 16-bit words
  30              	
  31              	.extern print_stringz
  32              	.extern u64toa
  33              	
  34              	.section .bss
  35              	    .align 16
  36 0000 00000000 	    .Lconv_buf:     .skip 20        # Buffer for u64toa conversion
  36      00000000 
  36      00000000 
  36      00000000 
  36      00000000 
  37              	    .lcomm .Lwinsize_struct, WINSIZE_SIZE 
  38              	
  39              	.section .rodata
  40              	    .Llabels:
  41 0000 726F7773 	        .ascii "rows    : \0"
  41      20202020 
  41      3A2000
  42 000b 636F6C75 	        .ascii "columns : \0"
  42      6D6E7320 
  42      3A2000
  43 0016 78706978 	        .ascii "xpixels : \0"
  43      656C7320 
  43      3A2000
  44 0021 79706978 	        .ascii "ypixels : \0"
  44      656C7320 
  44      3A2000
  45              	    .equ ITEM_SIZE, 11              # Bytes per null-terminated label string
  46              	    .equ ITEM_COUNT, 4
  47              	
GAS LISTING tui/basics/winsize/winsize.s 			page 2


  48 002c 0A00     	    .Lcrlf: .ascii "\n\0"
  49              	
  50              	.section .text
  51              	    .globl _start
  52              	
  53              	_start:
  54              	    # 1. Get terminal size via ioctl
  55              	    # sys_ioctl(fd: stdout, request: TIOCGWINSZ, arg: &winsize_struct)
  56:tui/basics/winsize/winsize.s ****     movl    $stdout, %edi
  57:tui/basics/winsize/winsize.s ****     movl    $TIOCGWINSZ, %esi
  58:tui/basics/winsize/winsize.s ****     leaq    .Lwinsize_struct(%rip), %rdx
  59:tui/basics/winsize/winsize.s ****     movl    $ioctl, %eax
  60:tui/basics/winsize/winsize.s ****     syscall
  61              	
  62              	    # 2. Initialize Loop Pointers
  63              	    # Using callee-saved registers to maintain stability across library calls
  64:tui/basics/winsize/winsize.s ****     leaq    .Llabels(%rip), %r13    # R13 = Current Label pointer
  65:tui/basics/winsize/winsize.s ****     leaq    .Lwinsize_struct(%rip), %r14 # R14 = Current Struct data pointer
  66:tui/basics/winsize/winsize.s ****     movq    $ITEM_COUNT, %r15       # R15 = Counter (4 items)
  67              	
  68              	.LnextVariable:
  69              	    # --- Step 1: Print the Label ---
  70:tui/basics/winsize/winsize.s ****     movl    $stdout, %edi
  71:tui/basics/winsize/winsize.s ****     movq    %r13, %rsi
  72:tui/basics/winsize/winsize.s ****     call    print_stringz           # ABI-transparent print
  73              	
  74              	    # --- Step 2: High-Performance Conversion (u64toa) ---
  75              	    # Convert 16-bit word to decimal string using magic numbers
  76:tui/basics/winsize/winsize.s ****     movzwl  (%r14), %edi            # Load 16-bit value into RDI
  77:tui/basics/winsize/winsize.s ****     leaq    .Lconv_buf(%rip), %rsi  # Destination buffer
  78:tui/basics/winsize/winsize.s ****     movq    $20, %rdx               # Buffer length
  79:tui/basics/winsize/winsize.s ****     call    u64toa                  # Returns RSI = start of digits, RDX = length
  80              	    
  81              	    # --- Step 3: Print the Digits ---
  82              	    # u64toa optimizes by returning the exact RDX and RSI needed for sys_write
  83:tui/basics/winsize/winsize.s ****     movl    $stdout, %edi           # File descriptor
  84:tui/basics/winsize/winsize.s ****     movl    $write, %eax            # sys_write
  85:tui/basics/winsize/winsize.s ****     syscall
  86              	
  87              	    # --- Step 4: Print Newline ---
  88:tui/basics/winsize/winsize.s ****     movl    $stdout, %edi
  89:tui/basics/winsize/winsize.s ****     leaq    .Lcrlf(%rip), %rsi
  90:tui/basics/winsize/winsize.s ****     call    print_stringz           #
  91              	    
  92              	    # --- Step 5: Increment and Loop ---
  93:tui/basics/winsize/winsize.s ****     addq    $2, %r14                # Move to next 16-bit word in winsize struct
  94:tui/basics/winsize/winsize.s ****     addq    $ITEM_SIZE, %r13        # Move to next null-terminated label
  95:tui/basics/winsize/winsize.s ****     decq    %r15
  96:tui/basics/winsize/winsize.s ****     jnz     .LnextVariable
  97              	
  98              	    # Exit
  99:tui/basics/winsize/winsize.s ****     movl    $exit, %eax
 100:tui/basics/winsize/winsize.s ****     xorl    %edi, %edi
 101:tui/basics/winsize/winsize.s ****     syscall
 102              	
 103              	.size _start, . - _start
 104              	.section .note.GNU-stack,"",@progbits
