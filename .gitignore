# ==========================================
# asm-linux-x86_64 .gitignore
# ==========================================

# --- 1. The Build Architecture ---
# Completely ignores the isolated output trees (both release and debug)
build/

# --- 2. Assembly & Linker Artifacts ---
# Fallbacks in case artifacts are ever generated outside the build/ dir
*.o
*.a
*.lst
*.map

# --- 3. Executables ---
# Standard Linux executable extensions and fallbacks
*.out
*.run
*.bin

# --- 4. Editor & OS Temporary Files ---
*~
*.swp
*.swo
.DS_Store
